<footer>
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-col">
        <p class="footer-logo"><img src="/images/logo/astrolads-logo-wit.png" alt="Astrolads" /> <span>Community</span></p>
        <p class="footer-tagline">Een broedplaats voor creatief talent in Den Haag.</p>
      </div>
      <div class="footer-col">
        <p class="footer-titel">Community</p>
        <a href="/community">Home</a>
        <a href="/community/events">Events</a>
        <a href="/community/initiatieven">Initiatieven</a>
        <a href="/community/initiatieven#pitch">Pitch je idee</a>
      </div>
      <div class="footer-col">
        <p class="footer-titel">Contact</p>
        <p>Astrolads B.V.</p>
        <p>Grote Markt 22</p>
        <p>2511 BG Den Haag</p>
        <a href="mailto:info@astrolads.com">info@astrolads.com</a>
      </div>
      <div class="footer-col">
        <p class="footer-titel">Volg ons</p>
        <a href="https://www.instagram.com/astroladsnl" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://www.tiktok.com/@astrolads" target="_blank" rel="noopener noreferrer">TikTok</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} Astrolads B.V.</p>
      <div class="footer-bottom-links">
        <a href="/privacy">Privacy & Cookies</a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--night-surface);
    border-top: 1px solid var(--night-border);
    color: var(--night-text);
    padding: 64px 40px 32px;
    margin-top: 96px;
  }
  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }
  .footer-col { display: flex; flex-direction: column; gap: 8px; }
  .footer-col a { color: var(--night-muted); text-decoration: none; font-size: 14px; transition: color .2s; }
  .footer-col a:hover { color: var(--orange); }
  .footer-col p { color: var(--night-muted); font-size: 14px; }
  .footer-logo {
    font-size: 22px;
    font-weight: 700;
    color: var(--night-text);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    line-height: 1;
  }
  .footer-logo img { height: 45px; width: auto; display: block; }
  .footer-logo span {
    color: var(--orange);
    position: relative;
    top: 2px;
  }
  .footer-tagline { color: var(--night-muted); margin-top: 8px; max-width: 280px; }
  .footer-titel {
    font-size: 12px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .08em;
    color: var(--night-text);
    margin-bottom: 4px;
  }
  .footer-bottom {
    display: flex; justify-content: space-between; align-items: center;
    padding-top: 24px;
    border-top: 1px solid var(--night-border);
    font-size: 13px; color: var(--night-muted);
  }
  .footer-bottom-links { display: flex; gap: 24px; }
  .footer-bottom-links a { 
    color: var(--night-muted); 
    text-decoration: none; 
    font-size: 13px;
    transition: color .2s;
  }
  .footer-bottom-links a:hover { color: var(--orange); }
  
  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }
</style>