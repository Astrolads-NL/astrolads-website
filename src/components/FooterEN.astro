---
const adviceServices = [
  { label: 'Communication strategy', href: '/en/services/communication-strategy' },
  { label: 'Education innovation', href: '/en/services/education-innovation' },
  { label: 'AI implementation', href: '/en/services/ai-implementation' },
];
const creationServices = [
  { label: 'Photography', href: '/en/services/photography' },
  { label: 'Podcast', href: '/en/services/podcast' },
  { label: 'Social media', href: '/en/services/socials' },
  { label: 'Software', href: '/en/services/software' },
  { label: 'Video', href: '/en/services/video' },
  { label: 'Graphic Design', href: '/en/services/graphic-design' },
  { label: 'Webinar & Livestream', href: '/en/services/webinar' },
  { label: 'Website', href: '/en/services/website' },
];
const cases = [
  { label: 'Natuurlijk!Deelmobiliteit', slug: 'deelmobiliteit' },
  { label: 'NSOB', slug: 'nsob' },
  { label: 'BOB-KOB', slug: 'bob-kob' },
  { label: 'Post-War Foundation', slug: 'na-de-oorlog' },
  { label: 'Rli', slug: 'rli' },
  { label: 'Dutch EV Drivers Association', slug: 'vereniging-elektrische-rijders' },
];
---

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/en" class="logo" aria-label="Astrolads"><img src="/images/logo/astrolads-logo.png" alt="Astrolads" /></a>
      <address>
        <p>Astrolads B.V.</p>
        <p>Grote Markt 22</p>
        <p>2511 BG The Hague</p>
        <br />
        <p><a href="tel:+31619409425">+31 6 1940 9425</a></p>
        <p><a href="mailto:info@astrolads.com">info@astrolads.com</a></p>
        <br />
        <p>KVK: 42028133</p>
      </address>
      <div class="socials">
        <a href="https://linkedin.com/company/astrolads" aria-label="LinkedIn" rel="noopener noreferrer">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </div>

    <div class="footer-col footer-col-advies">
      <h3>Advice</h3>
      <ul>
        {adviceServices.map(d => <li><a href={d.href}>{d.label}</a></li>)}
      </ul>
    </div>

    <div class="footer-col footer-col-creatie">
      <h3>Creation & production</h3>
      <ul>
        {creationServices.map(d => <li><a href={d.href}>{d.label}</a></li>)}
      </ul>
    </div>

    <div class="footer-col">
      <h3>Cases</h3>
      <ul>
        {cases.map(c => <li><a href={'/en/cases/' + c.slug}>{c.label}</a></li>)}
      </ul>
    </div>

    <div class="footer-col">
      <h3>About us</h3>
      <ul>
        <li><a href="/en/about">Our team</a></li>
        <li><a href="/en/about">Mission</a></li>
      </ul>
      <h3 style="margin-top:28px">Contact</h3>
      <ul>
        <li><a href="/en/contact">Get in touch</a></li>
        <li><a href="/en/faq">FAQ</a></li>
      </ul>
    </div>

    <img src="/images/raket.webp" alt="" class="footer-raket" aria-hidden="true" />
  </div>

  <div class="footer-bottom-wrap">
    <div class="footer-bottom">
      <span>© Copyright {new Date().getFullYear()} Astrolads</span>
      <div class="footer-bottom-links">
        <a href="/en/faq">FAQ</a>
        <a href="/en/privacy">Privacy & Cookies</a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--bg);
    padding: 64px 40px 0;
    border-top: 1px solid rgba(0,0,0,.08);
    overflow: hidden;
  }
  .footer-inner {
    max-width: var(--max-w); margin: 0 auto;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr 1fr;
    gap: 32px;
    padding-bottom: 56px;
    position: relative;
  }
  .footer-brand .logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    margin-bottom: 28px;
    position: relative;
    top: -2px;
  }
  .footer-brand .logo img {
    height: 45px;
    width: auto;
    display: block;
  }
  address {
    font-style: normal; font-size: 13px;
    color: var(--muted); line-height: 2;
  }
  address a { color: var(--muted); text-decoration: none; }
  address a:hover { color: var(--text); }
  .socials { display: flex; gap: 16px; margin-top: 20px; align-items: center; }
  .socials a {
    color: var(--text); text-decoration: none;
    transition: opacity .2s;
  }
  .socials a:hover { opacity: .6; }

  .footer-col h3 {
    font-weight: 700; font-size: 14px; margin-bottom: 20px;
  }
  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 14px; }
  .footer-col ul a { text-decoration: none; color: var(--muted); font-size: 13px; transition: color .2s; }
  .footer-col ul a:hover { color: var(--text); }

  .footer-raket {
    position: absolute;
    right: -80px; bottom: -40px;
    width: 320px;
    opacity: .12;
    pointer-events: none;
  }

  .footer-bottom-wrap {
    background: var(--navy);
    margin: 0 -40px;
    padding: 0 40px;
  }
  .footer-bottom {
    padding: 20px 0;
    max-width: var(--max-w); margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
    font-size: 12px; color: rgba(255,255,255,.6);
  }
  .footer-bottom-links { display: flex; gap: 24px; }
  .footer-bottom a { color: rgba(255,255,255,.6); text-decoration: none; }
  .footer-bottom a:hover { color: #fff; }

  @media (max-width: 768px) {
    footer { padding: 40px 20px 0; }
    .footer-inner {
      grid-template-columns: 1.4fr 1fr;
      gap: 28px 20px;
      padding-bottom: 40px;
    }
    .footer-brand .logo { margin-bottom: 20px; }
  .footer-brand .logo img { height: 45px; width: auto; display: block; }
    .footer-col h3 { margin-bottom: 14px; font-size: 13px; }
    .footer-col ul { gap: 10px; }

    /* Verberg Advice, Creation en Cases kolommen op mobile */
    .footer-col-advies,
    .footer-col-creatie,
    .footer-col:nth-of-type(4) {
      display: none;
    }
    /* Op mobile: alleen About us-kolom rechts naast brand zichtbaar (Contact tonen) */
    .footer-col:nth-of-type(5) h3:first-child,
    .footer-col:nth-of-type(5) ul:nth-of-type(1) {
      display: none;
    }
    .footer-col:nth-of-type(5) h3 + h3,
    .footer-col:nth-of-type(5) h3[style*="margin-top"] {
      margin-top: 0 !important;
    }
    .footer-col:nth-of-type(5) {
      align-self: start;
      margin-top: 48px;
    }

    /* Raket subtiel rechtsonder */
    .footer-raket {
      display: block;
      width: 180px;
      right: -50px; bottom: -30px;
      opacity: .1;
    }

    .footer-bottom-wrap {
      margin: 0 -20px;
      padding: 0 20px;
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
      padding: 20px 0;
      text-align: left;
    }
    .footer-bottom-links {
      gap: 16px;
      flex-wrap: wrap;
    }
  }
</style>