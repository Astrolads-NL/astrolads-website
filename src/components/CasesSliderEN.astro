---
const { currentSlug } = Astro.props;

const cases = [
  { slug: 'deelmobiliteit', tag: 'Natuurlijk!Deelmobiliteit', titel: 'Accelerating shared mobility in the Netherlands', img: '/images/cases/deelmobiliteit.webp' },
  { slug: 'nsob', tag: 'Netherlands School of Public Administration', titel: 'High-quality education and well-founded research on the public sector', img: '/images/cases/nsob.webp' },
  { slug: 'bob-kob', tag: 'BOB-KOB', titel: 'Practice-oriented training that strengthens craftsmanship in construction and infrastructure.', img: '/images/cases/bob-kob.webp' },
  { slug: 'na-de-oorlog', tag: 'Post-War Foundation', titel: 'Passing on stories from the Second World War to new generations.', img: '/images/cases/na-de-oorlog.webp' },
  { slug: 'rli', tag: 'Council for the Environment and Infrastructure', titel: 'Advisory council for government and parliament on housing, spatial planning and environment.', img: '/images/cases/rli.webp' },
  { slug: 'vereniging-elektrische-rijders', tag: 'Dutch EV Drivers Association', titel: 'The voice of electric driving in the Netherlands.', img: '/images/cases/ver.webp' },
  { slug: 'nkl-nederland', tag: 'NKL Nederland', titel: 'Trusted knowledge on charging infrastructure for policymakers and businesses', img: '/images/cases/nkl-nederland.webp' },
];

const andereCases = cases.filter(c => c.slug !== currentSlug);
---

<section class="cases-slider-component">
  <h2>Discover more cases</h2>

  <div class="cases-scroll" id="otherCasesScroll">
    {andereCases.map(c => (
      <a href={'/en/cases/' + c.slug} class="case-card">
        <img src={c.img} alt={c.tag} width="520" height="320" loading="lazy" />
        <div class="case-card-body">
          <p class="case-tag">{c.tag}</p>
          <h3>{c.titel} <span>›</span></h3>
        </div>
      </a>
    ))}
  </div>

  <div class="carousel-nav">
    <button class="carousel-btn" onclick="scrollOtherCases(-1)" aria-label="Previous case">←</button>
    <button class="carousel-btn" onclick="scrollOtherCases(1)" aria-label="Next case">→</button>
  </div>
</section>

<style>
  .cases-slider-component {
    margin-top: 80px;
    padding-top: 60px;
    border-top: 1px solid rgba(0,0,0,.08);
  }
  .cases-slider-component h2 {
    font-size: 32px; font-weight: 700;
    margin-bottom: 32px;
  }

  .cases-scroll {
    display: flex; gap: 20px;
    overflow-x: auto; overflow-y: visible;
    scroll-snap-type: x mandatory;
    padding: 16px 4px 24px;
    -ms-overflow-style: none; scrollbar-width: none;
  }
  .cases-scroll::-webkit-scrollbar { display: none; }
  .case-card {
    flex: 0 0 260px; scroll-snap-align: start;
    background: var(--white); border-radius: var(--radius);
    overflow: hidden; text-decoration: none; color: inherit;
    transition: transform .2s, box-shadow .2s;
  }
  .case-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,.1); }
  .case-card img { width: 100%; height: 160px; object-fit: cover; }
  .case-card-body { padding: 16px; }
  .case-tag { font-size: 11px; font-weight: 700; color: var(--orange-dark); text-transform: uppercase; letter-spacing: .07em; margin-bottom: 6px; }
  .case-card-body h3 { font-size: 15px; font-weight: 700; line-height: 1.3; display: flex; justify-content: space-between; gap: 8px; }
  .case-card-body h3 span { color: var(--muted); flex-shrink: 0; }

  .carousel-nav { display: flex; gap: 12px; justify-content: flex-end; margin-top: 24px; }
  .carousel-btn {
    width: 44px; height: 44px; border-radius: 50%;
    border: 1.5px solid rgba(0,0,0,.2); background: transparent;
    cursor: pointer; font-size: 16px; transition: background .2s;
  }
  .carousel-btn:hover { background: var(--white); }

  @media (max-width: 768px) {
    .cases-slider-component {
      margin-top: 56px;
      padding-top: 40px;
    }
    .cases-slider-component h2 {
      font-size: 24px;
      margin-bottom: 20px;
    }
    .cases-scroll {
      margin: 0 -20px;
      padding: 16px 20px 24px;
      scroll-padding-left: 20px;
      gap: 12px;
    }
    .case-card {
      flex: 0 0 calc(100% - 60px);
    }
    .carousel-nav { display: none; }
  }
</style>

<script>
  function scrollOtherCases(dir) {
    var el = document.getElementById('otherCasesScroll');
    if (el) el.scrollBy({ left: dir * 280, behavior: 'smooth' });
  }
  window.scrollOtherCases = scrollOtherCases;
</script>