---
import LayoutEN from '../../../layouts/LayoutEN.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';

const toepassingen = [
  {
    titel: 'A constant stream of current content',
    tekst: 'A website isn\'t finished once the last page is written and the call-to-action button has the right colour. A website is in that sense a living organism that constantly needs to move with the times and stay current. That\'s why we like to think along with you about interesting forms and ways to make your website more than just a static database, but a dynamic platform with current content. Think of news pages, blogs, reportages or other forms.',
  },
  {
    titel: 'Your website through the carwash',
    tekst: 'Already have a website but it doesn\'t feel right anymore? Then we don\'t need to start over completely. With a UI/UX scan, we look at all the low-hanging fruit that can be directly adjusted on your existing website and where the quick wins are. A fast and budget-friendly way to get the most out of your existing website!',
  },
];
---

<LayoutEN
  title="Website"
  description="Web design and web development by Astrolads. From landing pages to knowledge bases and complete corporate websites. Smart, user-friendly and brand-consistent."
  image="/images/og/diensten/website.jpg"
>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Web design and web development",
    "provider": { "@type": "Organization", "name": "Astrolads", "@id": "https://astrolads.com/#organization" },
    "areaServed": { "@type": "Country", "name": "Netherlands" },
    "description": "Web design and web development for landing pages, e-learnings, knowledge bases and complete corporate websites. Including UI/UX scans and further development.",
    "url": "https://astrolads.com/en/services/website"
  })} />

  <div class="dienst-page">
    <div class="section-inner">
      <Breadcrumb 
        lang="en"
        items={[
          { name: 'Services', url: '/en/services' },
          { name: 'Website' }
        ]} 
      />

      <!-- Header -->
      <div class="dienst-header">
        <div class="dienst-header-titel">
          <p class="section-label">Services</p>
          <h1>Website</h1>
        </div>
        <div class="dienst-header-img">
          <img src="/images/diensten/website-klein-tot-groot.webp" alt="Astrolads website development" width="640" height="480" loading="eager" fetchpriority="high" decoding="sync" />
        </div>
        <div class="dienst-header-tekst">
          <p class="dienst-intro">This is the Rome where all those online roads lead. Your online headquarters where your audience should feel at home, be able to navigate around and be taken on the journey you have in mind. By making your website smart, user-friendly and brand-consistent, you create a content-rich home base for your audience.</p>
          <p class="dienst-intro">Whether it's a simple landing page, temporary e-learning or an extensive knowledge base, we think along from the drawing board and build the complete website. We always think from the end user's perspective. What does the website visitor want to see and how do we ensure the website experience is as smooth as possible?</p>
          <a href="/en/contact" class="btn-orange">Get in touch</a>
        </div>
      </div>

      <!-- Applications -->
      <div class="website-toepassingen">
        <h2 class="toepassingen-titel">More than just building</h2>
        <div class="toepassingen-grid">
          {toepassingen.map(t => (
            <div class="toepassing-kaart">
              <h3>{t.titel}</h3>
              <p>{t.tekst}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="dienst-cta">
        <h2>Ready to get started?</h2>
        <p>Curious what a new or renewed website can do for your organisation? We're happy to think along with you.</p>
        <a href="/en/contact" class="btn-orange">Get in touch</a>
      </div>

    </div>
  </div>

</LayoutEN>

<style>
  .dienst-page { padding: 64px 0 96px; }

  .dienst-header {
    display: grid; grid-template-columns: 1fr 1fr;
    grid-template-areas:
      "titel slider"
      "tekst slider";
    gap: 0 80px; align-items: start;
    margin-bottom: 120px;
  }
  .dienst-header-titel { grid-area: titel; align-self: end; padding-bottom: 16px; }
  .dienst-header-img { grid-area: slider; align-self: center; }
  .dienst-header-tekst { grid-area: tekst; }
  .dienst-header-titel h1 {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 700; line-height: 1.1;
    margin-bottom: 0;
  }
  .dienst-intro {
    font-size: 17px; color: var(--muted);
    line-height: 1.7; margin-bottom: 24px;
  }
  .dienst-intro + .dienst-intro { margin-top: -8px; margin-bottom: 32px; }
  .dienst-header-img img {
    width: 100%; border-radius: var(--radius);
    object-fit: contain; height: 460px;
  }

  .website-toepassingen { margin-bottom: 120px; }
  .toepassingen-titel {
    font-size: 32px; font-weight: 700;
    margin-bottom: 48px; text-align: center;
  }
  .toepassingen-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .toepassing-kaart {
    background: var(--white);
    border-radius: var(--radius);
    padding: 40px;
    display: flex; flex-direction: column;
    transition: transform .2s, box-shadow .2s;
  }
  .toepassing-kaart:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,.08); }

  .toepassing-kaart h3 {
    font-size: 22px; font-weight: 700;
    margin-bottom: 16px; line-height: 1.3;
  }
  .toepassing-kaart p {
    color: var(--muted);
    line-height: 1.8; font-size: 15px;
  }

  .dienst-cta {
    text-align: center;
    background: var(--navy);
    border-radius: var(--radius);
    padding: 64px;
    color: #fff;
  }
  .dienst-cta h2 { font-size: 32px; font-weight: 700; margin-bottom: 16px; }
  .dienst-cta p { opacity: .8; margin-bottom: 32px; font-size: 16px; }

  @media (max-width: 768px) {
    .dienst-page { padding: 32px 0 56px; }

    /* Header: title → photo → text → button */
    .dienst-header {
      display: flex !important;
      flex-direction: column !important;
      grid-template-areas: none !important;
      grid-template-columns: 1fr !important;
      gap: 20px;
      margin-bottom: 56px;
    }
    .dienst-header-titel,
    .dienst-header-img,
    .dienst-header-tekst {
      grid-area: auto !important;
      align-self: auto !important;
      width: 100%;
    }
    .dienst-header-titel { order: 1 !important; }
    .dienst-header-img { order: 2 !important; }
    .dienst-header-tekst { order: 3 !important; }
    .dienst-header-titel {
      padding-bottom: 0;
    }
    .dienst-header-titel h1 {
      font-size: clamp(28px, 7vw, 36px);
      line-height: 1.15;
      margin-bottom: 0;
    }
    .dienst-intro {
      font-size: 14px;
      line-height: 1.7;
      margin-bottom: 16px;
    }
    .dienst-intro + .dienst-intro { margin-top: -4px; margin-bottom: 20px; }
    .dienst-header-img {
      width: 100%;
      display: flex;
      justify-content: center;
    }
    .dienst-header-img img {
      width: 100% !important;
      height: auto !important;
      aspect-ratio: auto !important;
      max-height: 280px;
      max-width: 100%;
      object-fit: contain;
    }

    /* Applications: 1 column */
    .website-toepassingen { margin-bottom: 56px; }
    .toepassingen-titel {
      font-size: 24px;
      margin-bottom: 24px;
    }
    .toepassingen-grid { grid-template-columns: 1fr; gap: 12px; }
    .toepassing-kaart { padding: 24px; }
    .toepassing-kaart h3 {
      font-size: 18px;
      margin-bottom: 12px;
    }
    .toepassing-kaart p {
      font-size: 14px;
      line-height: 1.7;
    }

    /* CTA compact */
    .dienst-cta {
      padding: 36px 24px;
    }
    .dienst-cta h2 {
      font-size: 22px;
      line-height: 1.3;
      margin-bottom: 12px;
    }
    .dienst-cta p {
      font-size: 14px;
      margin-bottom: 24px;
    }
  }
</style>