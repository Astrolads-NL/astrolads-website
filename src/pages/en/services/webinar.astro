---
import LayoutEN from '../../../layouts/LayoutEN.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';

const vormen = [
{
    titel: 'An interactive panel programme',
    tekst: 'The chair or presenter takes viewers through a substantive programme (optionally alternated with videos, think of a short break with street interviews about the next topic coming up). Viewers can ask live questions to the panel guests or, where needed, request additional depth.',
    mave: [
      { src: 'https://space-10z8x.video-dns.com/sSH54IMwML/player.html', titel: 'Webinar Rli' },
    ],
  },
  {
    titel: 'Callers from across the globe',
    tekst: 'From the Astrolads Studio, panel conversations can be broadcast worldwide. With technicians at the controls for slides, name tags and viewer questions, we ensure a flawless viewer experience that doesn\'t take away from the feel of a physical event. Due to the online nature, you reach practically the whole world from the Astrolads Studio, as long as they have an internet connection!',
    img: '/images/diensten/webinar-inbellers-4.webp',
  },
  {
    titel: 'Instantly valuable social content about the topic',
    tekst: 'Alongside broadcasting a livestream, with this form you immediately have a complete recording from which vertical videos or snippets can be cut for extra push on social media channels. Photography in the studio is also possible to include in, for example, a newsletter with the replay link.',
    fotoPositie: 'top',
    fotos: [
      '/images/diensten/webinar-social-1.webp',
      '/images/diensten/webinar-social-2.webp',
      '/images/diensten/webinar-social-3.webp',
      '/images/diensten/webinar-social-4.webp',
    ],
  },
  {
    titel: 'The right platform for every goal',
    tekst: 'Broadcasting can of course happen on the established video channel YouTube, but optionally also in Zoom, Teams or another streaming platform of choice. We\'re happy to advise on this. Our team ensures the script fits the media format, that viewers experience a flawless presentation with neat styling, an engaging intro/outro video where panel guests are introduced directly.',
    img: '/images/diensten/webinar-platform.webp',
  },
];
---

<LayoutEN
  title="Webinars & Livestreams"
  description="Webinars and livestreams from our studio in The Hague. Interactive panel programmes with live audience and expert panels, perfect for in-depth content."
  image="/images/og/diensten/webinar.jpg"
>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Webinars and livestreams",
    "provider": { "@type": "Organization", "name": "Astrolads", "@id": "https://astrolads.com/#organization" },
    "areaServed": { "@type": "Country", "name": "Netherlands" },
    "description": "Webinars and livestreams from our studio in The Hague. Interactive panel programmes with live audience, recorded for replay and social snippets.",
    "url": "https://astrolads.com/en/services/webinar"
  })} />

  <div class="dienst-page">
    <div class="section-inner">
      <Breadcrumb 
        lang="en"
        items={[
          { name: 'Services', url: '/en/services' },
          { name: 'Webinar' }
        ]} 
      />

      <!-- Header -->
      <div class="dienst-header">
        <div class="dienst-header-titel">
          <p class="section-label">Services</p>
          <h1>Webinars & Livestreams</h1>
        </div>
        <div class="dienst-header-img">
          <div class="header-slider">
            <img class="header-slide active" src="/images/diensten/webinar-slide-1.webp" alt="Astrolads webinar production" width="640" height="480" loading="eager" fetchpriority="high" decoding="sync" />
            <img class="header-slide" src="/images/diensten/webinar-slide-2.webp" alt="Astrolads webinar production" width="640" height="480" loading="lazy" />
            <img class="header-slide" src="/images/diensten/webinar-slide-3.webp" alt="Astrolads webinar production" width="640" height="480" loading="lazy" />
          </div>
        </div>
        <div class="dienst-header-tekst">
          <p class="dienst-intro">With some themes and topics, you really want to dive in with experts and people with first-hand experience. A Live Talkshow is the perfect format for that. Viewers get the chance to attend presentations, ask questions, join the conversation and fully absorb the content… all from their own desk chair (saves a lot of time, kilometres, and snack costs)!</p>
          <a href="/en/contact" class="btn-orange">Get in touch</a>
        </div>
      </div>

      <!-- Forms -->
      <div class="dienst-vormen">
        <h2 class="vormen-titel">What makes a livestream so powerful?</h2>
        <div class="vormen-grid">
          {vormen.map((v, i) => (
            <div class:list={['vorm-sectie', { flip: i % 2 !== 0 }]}>
              <div class="vorm-img">
                {'mave' in v ? (
                  <div class="mave-player">
                    <div class="mave-main">
                      <iframe
                        src={v.mave[0].src}
                        width="100%" height="100%"
                        frameborder="0" scrolling="no" allowfullscreen
                        id={'mave-' + v.titel.replace(/\s/g, '-')}
                        style="border-radius:16px;"
                      ></iframe>
                    </div>
                    {v.mave.length > 1 && (
                      <div class="mave-thumbs">
                        {v.mave.map((m, i) => (
                          <button
                            class:list={['mave-thumb', { active: i === 0 }]}
                            data-src={m.src}
                            data-player={'mave-' + v.titel.replace(/\s/g, '-')}
                          >
                            {m.titel}
                          </button>
                        ))}
                      </div>
                    )}
                  </div>
                ) : 'fotos' in v ? (
                  <div class:list={['vorm-fader', { 'fader-top': v.fotoPositie === 'top' }]}>
                    {v.fotos.map((f, i) => (
                      <img
                        src={f} alt={v.titel}
                        width="600" height="400" loading="lazy"
                        class:list={['fader-slide', { active: i === 0 }]}
                      />
                    ))}
                    <div class="fader-dots">
                      {v.fotos.map((_, i) => (
                        <button class:list={['fader-dot', { active: i === 0 }]} data-index={i} aria-label={'Photo ' + (i + 1)}></button>
                      ))}
                    </div>
                  </div>
                ) : (
                  <img src={v.img} alt={v.titel + ' by Astrolads'} width="600" height="400" loading="lazy" />
                )}
              </div>
              <div class="vorm-tekst">
                <h3>{v.titel}</h3>
                <p>{v.tekst}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="dienst-cta">
        <h2>Ready to get started?</h2>
        <p>Curious what a livestream or webinar can do for your organisation? We're happy to think along with you.</p>
        <a href="/en/contact" class="btn-orange">Get in touch</a>
      </div>

    </div>
  </div>

<script>
document.querySelectorAll('.mave-thumb').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var playerId = btn.getAttribute('data-player');
      var src = btn.getAttribute('data-src');
      var iframe = document.getElementById(playerId);
      if (iframe) iframe.src = src;
      var thumbs = btn.closest('.mave-thumbs').querySelectorAll('.mave-thumb');
      thumbs.forEach(function(t) { t.classList.remove('active'); });
      btn.classList.add('active');
    });
  });
  var slides = document.querySelectorAll('.header-slide');
  var current = 0;
  setInterval(function() {
    slides[current].classList.remove('active');
    current = (current + 1) % slides.length;
    slides[current].classList.add('active');
  }, 4000);

  document.querySelectorAll('.vorm-fader').forEach(function(fader) {
    var slides = fader.querySelectorAll('.fader-slide');
    var dots = fader.querySelectorAll('.fader-dot');
    var current = 0;
    function goTo(index) {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      current = index;
      slides[current].classList.add('active');
      dots[current].classList.add('active');
    }
    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        goTo(parseInt(dot.getAttribute('data-index')));
      });
    });
    if (slides.length > 1) {
      setInterval(function() {
        goTo((current + 1) % slides.length);
      }, 4000);
    }
  });
</script>

</LayoutEN>

<style>
  .dienst-page { padding: 64px 0 96px; }

  .dienst-header {
    display: grid; grid-template-columns: 1fr 1fr;
    grid-template-areas:
      "titel slider"
      "tekst slider";
    gap: 0 80px; align-items: start;
    margin-bottom: 120px;
  }
  .dienst-header-titel { grid-area: titel; align-self: end; padding-bottom: 16px; }
  .dienst-header-img { grid-area: slider; align-self: center; }
  .dienst-header-tekst { grid-area: tekst; }
  .dienst-header-titel h1 {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 700; line-height: 1.1;
    margin-bottom: 0;
  }
  .dienst-intro {
    font-size: 17px; color: var(--muted);
    line-height: 1.7; margin-bottom: 32px;
  }
  .dienst-header-img img { width: 100%; border-radius: var(--radius); object-fit: cover; height: 460px; }
  .header-slider { position: relative; height: 460px; border-radius: var(--radius); overflow: hidden; }
  .header-slide {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; opacity: 0;
    transition: opacity 1s ease;
  }
  .header-slide.active { opacity: 1; }
  .vormen-titel {
    font-size: 32px; font-weight: 700;
    margin-bottom: 64px; text-align: center;
  }

  .vorm-sectie {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: start;
    margin-bottom: 120px;
  }
  .vorm-sectie.flip .vorm-img { order: 2; }
  .vorm-sectie.flip .vorm-tekst { order: 1; }
  .vorm-img img { width: 100%; border-radius: var(--radius); object-fit: cover; height: 320px; }
  .mave-player { display: flex; flex-direction: column; gap: 12px; }
  .mave-main { width: 100%; aspect-ratio: 16/9; border-radius: var(--radius); overflow: hidden; background: #000; }
  .mave-main iframe { width: 100%; height: 100%; border: none; }
  .mave-thumbs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .mave-thumb {
    flex: 1; padding: 7px 12px;
    border: 1.5px solid rgba(0,0,0,.12);
    border-radius: 999px; background: var(--white);
    font-family: var(--font); font-size: 12px;
    cursor: pointer; transition: all .2s;
    color: var(--muted); white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis;
  }
  .mave-thumb:hover { border-color: var(--orange); color: var(--orange); }
  .mave-thumb.active { border-color: var(--orange); color: var(--orange); font-weight: 700; }
  .vorm-tekst h3 { font-size: 28px; font-weight: 700; margin-bottom: 16px; }
  .vorm-tekst p { color: var(--muted); line-height: 1.8; font-size: 15px; }

  .vorm-fader {
    position: relative; border-radius: var(--radius);
    overflow: hidden; aspect-ratio: 3/2;
  }
  .vorm-fader .fader-slide {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center center;
    opacity: 0;
    transition: opacity .8s ease;
  }
  .vorm-fader.fader-top .fader-slide {
    object-position: center 20%;
  }
  .vorm-fader .fader-slide.active { opacity: 1; }
  .vorm-fader .fader-dots {
    position: absolute; bottom: 16px; left: 50%;
    transform: translateX(-50%);
    display: flex; gap: 8px; z-index: 2;
  }
  .vorm-fader .fader-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(255,255,255,.5);
    border: none; cursor: pointer; padding: 0;
    transition: background .2s;
  }
  .vorm-fader .fader-dot.active { background: #fff; }

  .dienst-cta {
    text-align: center;
    background: var(--navy);
    border-radius: var(--radius);
    padding: 64px;
    color: #fff;
  }
  .dienst-cta h2 { font-size: 32px; font-weight: 700; margin-bottom: 16px; }
  .dienst-cta p { opacity: .8; margin-bottom: 32px; font-size: 16px; }

  @media (max-width: 768px) {
    .dienst-page { padding: 32px 0 56px; }

    /* Header: title → slider → text → button */
    .dienst-header {
      display: flex !important;
      flex-direction: column !important;
      grid-template-areas: none !important;
      grid-template-columns: 1fr !important;
      gap: 20px;
      margin-bottom: 56px;
    }
    .dienst-header-titel,
    .dienst-header-img,
    .dienst-header-tekst {
      grid-area: auto !important;
      align-self: auto !important;
      width: 100%;
    }
    .dienst-header-titel {
      padding-bottom: 0;
    }
    .dienst-header-titel h1 {
      font-size: clamp(28px, 7vw, 36px);
      line-height: 1.15;
      margin-bottom: 0;
    }
    .dienst-intro {
      font-size: 14px;
      line-height: 1.7;
      margin-bottom: 20px;
    }
    .header-slider {
      height: auto !important;
      aspect-ratio: 16 / 9;
      width: 100%;
      position: relative;
    }
    .header-slider .header-slide {
      position: absolute !important;
      inset: 0 !important;
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
    }

    /* Forms title */
    .vormen-titel {
      font-size: 24px;
      margin-bottom: 32px;
    }

    /* Form sections: title above, photo/player middle, text below */
    .vorm-sectie {
      display: flex; flex-direction: column;
      gap: 16px;
      margin-bottom: 48px;
    }
    .vorm-sectie .vorm-img { order: 2; }
    .vorm-sectie .vorm-tekst { order: 1; display: contents; }
    .vorm-sectie .vorm-tekst h3 { order: 1; }
    .vorm-sectie .vorm-tekst p { order: 3; }
    .vorm-sectie.flip .vorm-img { order: 2; }
    .vorm-img { width: 100%; }

    /* Vorm-fader 16:9 on mobile */
    .vorm-fader {
      aspect-ratio: 16 / 9 !important;
      height: auto !important;
      width: 100%;
      position: relative;
    }
    .vorm-fader .fader-slide {
      position: absolute !important;
      inset: 0 !important;
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
    }

    /* Single images 16:9 */
    .vorm-img > img {
      aspect-ratio: 16 / 9 !important;
      height: auto !important;
    }

    /* Mave-player thumbs wrappable */
    .mave-thumbs {
      display: flex; flex-wrap: wrap;
      gap: 6px;
    }
    .mave-thumb {
      flex: 1 1 calc(50% - 4px);
      font-size: 11px;
      padding: 6px 10px;
    }

    .vorm-fader .fader-dot { width: 10px; height: 10px; }
    .vorm-tekst h3 {
      font-size: 20px;
      margin-bottom: 0;
    }
    .vorm-tekst p {
      font-size: 14px;
      line-height: 1.7;
    }

    /* CTA compact */
    .dienst-cta {
      padding: 36px 24px;
    }
    .dienst-cta h2 {
      font-size: 22px;
      line-height: 1.3;
      margin-bottom: 12px;
    }
    .dienst-cta p {
      font-size: 14px;
      margin-bottom: 24px;
    }
  }
</style>