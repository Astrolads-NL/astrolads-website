---
import LayoutEN from '../../../layouts/LayoutEN.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';

const vormen = [
  {
    titel: 'Full channel management',
    tekst: 'An active channel calls for consistency. From planning and posting content to keeping up with reactions and messages, we take the daily management of your social media channels off your hands. That way your message stays visible and your audience engaged. We create a wide variety of content and make sure the right tone is hit for every sub-audience. We like to work according to the principle of "macro to micro" content creation: turning larger content formats like a website or podcast into small, digestible videos, images and carousels, so the knowledge is visible where your audience prefers to be.',
    img: '/images/diensten/socials-beheer.webp',
  },
  {
    titel: 'Advertising campaigns',
    tekst: 'With the right advertising strategy, you amplify the effect and reach the right people. We think along about audiences, budgets and formats, and adjust where needed. Data is more than just clicks and views. Many of the organisations we work with deal with multiple themes that need to land with different audiences. For optimal monitoring and optimisation, we use custom-made benchmarking per theme and audience. Alongside online data, we also look at audience sentiment and qualitative results.',
    img: '/images/diensten/socials-advertenties.webp',
  },
];
---

<LayoutEN
  title="Social Media"
  description="Social media management and advertising campaigns by Astrolads. From content strategy to daily management on LinkedIn, TikTok, Instagram and Facebook. Reach your audience."
  image="/images/og/diensten/socials.jpg"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Social media",
    "provider": { "@type": "Organization", "name": "Astrolads", "@id": "https://astrolads.com/#organization" },
    "areaServed": { "@type": "Country", "name": "Netherlands" },
    "description": "Social media content strategy, channel management and advertising campaigns on LinkedIn, TikTok, Instagram and Facebook.",
    "url": "https://astrolads.com/en/services/socials"
  })} />

  <div class="dienst-page">
    <div class="section-inner">
      <Breadcrumb 
        lang="en"
        items={[
          { name: 'Services', url: '/en/services' },
          { name: 'Socials' }
        ]} 
      />

      <!-- Header -->
      <div class="dienst-header">
        <div class="dienst-header-titel">
          <p class="section-label">Services</p>
          <h1>Social Media</h1>
        </div>
        <div class="dienst-header-img">
          <img src="/images/diensten/socials-header.webp" alt="Astrolads social media" width="640" height="480" loading="eager" fetchpriority="high" decoding="sync" />
        </div>
        <div class="dienst-header-tekst">
          <p class="dienst-intro">Vertical videos, design, sharp copy; on social media all media forms come together. At Astrolads we take care of setting up and executing your social media content strategy, with or without advertising. But delivering individual content for campaigns happens just as often.</p>
          <p class="dienst-intro">LinkedIn, TikTok, Instagram and Facebook. At Astrolads we have all the expertise in-house to reach your audience together with you, in a way that matches the tone of each platform.</p>
          <a href="/en/contact" class="btn-orange">Get in touch</a>
        </div>
      </div>

      <!-- Forms -->
      <div class="dienst-vormen">
        <h2 class="vormen-titel">What can we do for you?</h2>
        <div class="vormen-grid">
          {vormen.map((v, i) => (
            <div class:list={['vorm-sectie', { flip: i % 2 !== 0 }]}>
              <div class="vorm-img">
                <img src={v.img} alt={v.titel + ' by Astrolads'} width="600" height="400" loading="lazy" />
              </div>
              <div class="vorm-tekst">
                <h3>{v.titel}</h3>
                <p>{v.tekst}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="dienst-cta">
        <h2>Not entirely sure about the right approach?</h2>
        <p>Let us think along with you and work this out into a complete communication strategy.<br />Together we'll look at which channels, audiences and formats best fit your organisation.</p>
        <a href="/en/services/communication-strategy" class="btn-orange">To communication strategy</a>
      </div>

    </div>
  </div>

</LayoutEN>

<style>
  .dienst-page { padding: 64px 0 96px; }

  .dienst-header {
    display: grid; grid-template-columns: 1fr 1fr;
    grid-template-areas:
      "titel slider"
      "tekst slider";
    gap: 0 80px; align-items: start;
    margin-bottom: 120px;
  }
  .dienst-header-titel { grid-area: titel; align-self: end; padding-bottom: 16px; }
  .dienst-header-img { grid-area: slider; align-self: center; }
  .dienst-header-tekst { grid-area: tekst; }
  .dienst-header-titel h1 {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 700; line-height: 1.1;
    margin-bottom: 0;
  }
  .dienst-intro {
    font-size: 17px; color: var(--muted);
    line-height: 1.7; margin-bottom: 24px;
  }
  .dienst-intro + .dienst-intro { margin-top: -8px; margin-bottom: 32px; }
  .dienst-header-img img { width: 100%; border-radius: var(--radius); object-fit: cover; height: 460px; }

  .vormen-titel {
    font-size: 32px; font-weight: 700;
    margin-bottom: 64px; text-align: center;
  }

  .vorm-sectie {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: start;
    margin-bottom: 120px;
  }
  .vorm-sectie.flip .vorm-img { order: 2; }
  .vorm-sectie.flip .vorm-tekst { order: 1; }
  .vorm-img img {
    width: 100%; border-radius: var(--radius);
    object-fit: contain; height: 560px;
  }
  .vorm-tekst h3 { font-size: 28px; font-weight: 700; margin-bottom: 16px; }
  .vorm-tekst p { color: var(--muted); line-height: 1.8; font-size: 15px; }

  .dienst-cta {
    text-align: center;
    background: var(--navy);
    border-radius: var(--radius);
    padding: 64px;
    color: #fff;
    margin-top: 40px;
  }
  .dienst-cta h2 { font-size: 32px; font-weight: 700; margin-bottom: 16px; }
  .dienst-cta p { opacity: .8; margin-bottom: 32px; font-size: 16px; }

  @media (max-width: 768px) {
    .dienst-page { padding: 32px 0 56px; }

    /* Header: title → photo → text → button */
    .dienst-header {
      display: flex !important;
      flex-direction: column !important;
      grid-template-areas: none !important;
      grid-template-columns: 1fr !important;
      gap: 20px;
      margin-bottom: 56px;
    }
    .dienst-header-titel,
    .dienst-header-img,
    .dienst-header-tekst {
      grid-area: auto !important;
      align-self: auto !important;
      width: 100%;
    }
    .dienst-header-titel {
      padding-bottom: 0;
    }
    .dienst-header-titel h1 {
      font-size: clamp(28px, 7vw, 36px);
      line-height: 1.15;
      margin-bottom: 0;
    }
    .dienst-intro {
      font-size: 14px;
      line-height: 1.7;
      margin-bottom: 16px;
    }
    .dienst-intro + .dienst-intro { margin-top: -4px; margin-bottom: 20px; }
    .dienst-header-img img {
      width: 100%;
      height: auto !important;
      aspect-ratio: 16 / 9;
    }

    /* Forms title smaller */
    .vormen-titel {
      font-size: 24px;
      margin-bottom: 32px;
    }

    /* Vorm-secties: text above, photo below (centered) */
    .vorm-sectie {
      display: flex; flex-direction: column;
      gap: 16px;
      margin-bottom: 40px;
    }
    .vorm-sectie .vorm-img,
    .vorm-sectie.flip .vorm-img {
      order: 2;
      display: flex;
      justify-content: center;
      width: 100%;
      text-align: center;
    }
    .vorm-sectie .vorm-tekst { order: 1; }
    .vorm-img img {
      height: auto !important;
      aspect-ratio: 4 / 5;
      max-height: 280px;
      width: auto;
      max-width: 100%;
      object-fit: contain;
      display: block;
      margin: 0 auto;
    }
    .vorm-tekst h3 {
      font-size: 20px;
      margin-bottom: 8px;
    }
    .vorm-tekst p {
      font-size: 14px;
      line-height: 1.7;
    }

    /* CTA compact */
    .dienst-cta {
      padding: 36px 24px;
      margin-top: 24px;
    }
    .dienst-cta h2 {
      font-size: 22px;
      line-height: 1.3;
      margin-bottom: 12px;
    }
    .dienst-cta p {
      font-size: 14px;
      margin-bottom: 24px;
    }
  }
</style>