const cases = {
  'deelmobiliteit': {
    tag: 'Natuurlijk!Deelmobiliteit',
    titel: 'Accelerating shared mobility in the Netherlands',
    metaDescription: 'Astrolads as long-term communication partner of Natuurlijk!Deelmobiliteit. From podcast and webinars to print and graphic design for the Shared Mobility Rocks event.',
    intro: 'Shared mobility can mean a lot for society as a whole and for every resident personally. As an important part of the mobility network, it provides greater accessibility, room to build and live, and gives people freedom of choice. To remove the bottlenecks for further growth, 30 municipalities, regions, provinces and the national government started a National Cooperation Programme: Natuurlijk!Deelmobiliteit (N!D).',
    img: '/images/cases/deelmobiliteit.webp',
    themas: ['mobility', 'sustainability'],
    diensten: ['Podcast', 'Video', 'Webinars', 'Photography', 'Graphic Design', 'Print'],
    beschrijvingImg: '/images/cases/deelmobiliteit-beschrijving.webp',
