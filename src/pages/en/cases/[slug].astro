        fotos: [
          '/images/cases/ver-fotografie-1.webp',
          '/images/cases/ver-fotografie-2.webp',
          '/images/cases/ver-fotografie-3.webp',
          '/images/cases/ver-fotografie-4.webp',
          '/images/cases/ver-fotografie-5.webp',
          '/images/cases/ver-fotografie-6.webp',
          '/images/cases/ver-fotografie-7.webp',
