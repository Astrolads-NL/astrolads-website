    secties: [
      {
        label: 'Video',
        titel: 'Workshops and gatherings shared online so all interested parties can take in the content.',
        tekst: 'Everyone who works in the world of construction and/or infrastructure will agree: time is not abundant. All the more reason for the physical events of BOB-KOB to also be visible online, so everyone can still take in the content. To amplify the impact and knowledge sharing of all these workshops and gatherings, we make short in-depth aftermovies that can be shared online. Usable in newsletters, on social channels or as marketing material for future editions.',
        mave: [
          { src: 'https://space-10z8x.video-dns.com/xAPD6BJf7s/player.html', titel: 'VR/AI Experience' },
          { src: 'https://space-10z8x.video-dns.com/vBPFRTN6cK/player.html', titel: 'AI in education' },
