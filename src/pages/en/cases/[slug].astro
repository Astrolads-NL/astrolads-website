const data = cases[slug as keyof typeof cases];
if (!data) return Astro.redirect('/en/cases');
---

<LayoutEN title={data.titel} description={data.metaDescription} image={`/images/og/cases/${slug}.jpg`}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": data.titel,
    "description": data.intro,
    "image": `https://astrolads.com${data.img}`,
    "inLanguage": "en",
    "author": {
      "@type": "Organization",
      "name": "Astrolads",
      "@id": "https://astrolads.com/#organization"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Astrolads",
      "@id": "https://astrolads.com/#organization",
      "logo": {
        "@type": "ImageObject",
        "url": "https://astrolads.com/images/logo.webp"
      }
    },
    "about": {
      "@type": "Organization",
      "name": data.tag
    },
    "keywords": data.diensten.join(", "),
    "mainEntityOfPage": `https://astrolads.com/en/cases/${slug}`
  })} />

  <div class="case-detail">
    <div class="section-inner">
      <Breadcrumb 
        lang="en"
        items={[
          { name: 'Cases', url: '/en/cases' },
          { name: data.tag }
        ]} 
      />

      <!-- Header -->
      <div class="case-header">
        <div class="case-header-titel">
          <p class="section-label">{data.tag}</p>
          <h1>{data.titel}</h1>
        </div>
        <div class="case-header-img">
          <img src={data.img} alt={data.titel} width="640" height="420" loading="eager" fetchpriority="high" decoding="sync" />
        </div>
        <div class="case-header-left">
          <p class="case-intro">{data.intro}</p>
          <p class="diensten-label">Our services</p>
          <div class="case-pills">
            {data.diensten.map(d => <span class="pill">{d}</span>)}
          </div>
        </div>
      </div>

      <!-- Beschrijving -->
      {'beschrijving' in data && (
        <div class="case-beschrijving-sectie">
          {'beschrijvingImg' in data && (
            <div class="beschrijving-img">
              <img src={data.beschrijvingImg} alt={data.tag} width="600" height="400" loading="lazy" />
            </div>
          )}
          <div class="beschrijving-tekst">
            <p>{data.beschrijving}</p>
          </div>
        </div>
      )}

      <!-- Quote -->
      {'quote' in data && (
        <div class="case-quote-wrap">
          <div class="case-quote">
            <span class="quote-icon">&ldquo;</span>
            <blockquote>{data.quote.tekst}</blockquote>
            {'foto' in data.quote && (
              <img src={data.quote.foto} alt={data.quote.naam} class="quote-foto" />
            )}
          </div>
          <p class="quote-naam">{data.quote.naam}{'organisatie' in data.quote && <span class="quote-org">{data.quote.organisatie}</span>}</p>
        </div>
      )}

      <!-- Secties -->
      {data.secties.map(s => (
        <div class:list={['case-sectie', { flip: s.flip }]}>
          <div class="sectie-img">
            {'mave' in s ? (
              <div class="mave-player">
                <div class="mave-main">
                  <iframe
                    src={s.mave[0].src}
                    width="100%" height="100%"
                    frameborder="0" scrolling="no" allowfullscreen
                    id={'mave-main-' + s.label}
                    style="border-radius:16px;"
                  ></iframe>
                </div>
                {s.mave.length > 1 && (
                  <div class="mave-thumbs">
                    {s.mave.map((v, i) => (
                      <button
                        class:list={['mave-thumb', { active: i === 0 }]}
                        data-src={v.src}
                        data-player={'mave-main-' + s.label}
                      >
                        {v.titel}
                      </button>
                    ))}
                  </div>
                )}
              </div>
            ) : 'verticaal' in s ? (
              <div class="verticaal-swiper">
                <div class="verticaal-telefoon">
                  <div class="telefoon-scherm">
                    <iframe
                      src={s.verticaal[0].src}
                      width="100%" height="100%"
                      frameborder="0" scrolling="no" allowfullscreen
                      id={'vert-main-' + s.label}
                      style="border:none;"
                    ></iframe>
                  </div>
                </div>
                <div class="verticaal-nav">
                  {s.verticaal.map((m, i) => (
                    <button
                      class:list={['vert-thumb', { active: i === 0 }]}
                      data-src={m.src}
                      data-player={'vert-main-' + s.label}
                    >
                      {m.titel}
                    </button>
                  ))}
                </div>
              </div>
            ) : 'spotify' in s ? (
              <iframe
                src={s.spotify}
                width="100%"
                height="352"
                frameborder="0"
                allowfullscreen
                allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                loading="lazy"
                class="spotify-embed"
                style="border-radius:16px;"
              ></iframe>
            ) : 'fotos' in s ? (
              <div class="sectie-fader">
                {s.fotos.map((f, i) => (
                  <img
                    src={f} alt={s.titel}
                    width="600" height="400" loading="lazy"
                    class:list={['fader-slide', { active: i === 0 }]}
                  />
                ))}
                <div class="fader-dots">
                  {s.fotos.map((_, i) => (
                    <button class:list={['fader-dot', { active: i === 0 }]} data-index={i} aria-label={'Photo ' + (i + 1)}></button>
                  ))}
                </div>
              </div>
            ) : 'img' in s ? (
              <img src={s.img} alt={s.label + ' for ' + data.tag + ' by Astrolads'} width="600" height="400" loading="lazy" />
            ) : null}
          </div>
          <div class="sectie-tekst">
            <p class="sectie-label">{s.label}</p>
            <h2>{s.titel}</h2>
            <p>{s.tekst}</p>
          </div>
        </div>
      ))}

      <CasesSlider currentSlug={slug} />

    </div>
  </div>
</LayoutEN>

