---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Bedankt voor je bericht"
  description="We nemen zo snel mogelijk contact met je op."
>
  <div class="bedankt-page">
    <div class="section-inner">
      <div class="bedankt-card">
        <div class="bedankt-icoon" aria-hidden="true">✓</div>
        <h1>Bedankt voor je bericht!</h1>
        <p>We hebben je bericht goed ontvangen en nemen zo snel mogelijk contact met je op.</p>
        <a href="/" class="btn-orange">Terug naar home</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .bedankt-page {
    padding: 120px 0 160px;
    min-height: 60vh;
    display: flex;
    align-items: center;
  }
  .bedankt-card {
    background: var(--white);
    border-radius: var(--radius);
    padding: 64px 48px;
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }
  .bedankt-icoon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--orange);
    color: #fff;
    font-size: 36px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 32px;
  }
  .bedankt-card h1 {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 16px;
  }
  .bedankt-card p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin-bottom: 32px;
  }

  @media (max-width: 768px) {
    .bedankt-page { padding: 64px 0 96px; }
    .bedankt-card { padding: 40px 24px; }
    .bedankt-icoon {
      width: 56px;
      height: 56px;
      font-size: 28px;
      margin-bottom: 24px;
    }
    .bedankt-card p { font-size: 14px; }
  }
</style>