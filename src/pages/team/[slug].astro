    bioLang: 'Waar hij vroeger werd bestempeld als AD(H)D en iemand met een buitensporige behoefte aan prikkels en vernieuwing, zet Dave die eigenschappen nu in als zijn grootste kracht. Met eindeloze energie, ontwapende humor en sterke drang naar vooruitgang, zorgt Dave dat elk project vooruit komt en dat alle betrokkenen ook de waardering en het plezier ervaren dat het betekenisvolle werk met zich meebrengt. Vanuit een servicegerichte en pragmatische instelling, krijgt Dave energie van het meedenken met complexe vraagstukken en daarin de meest ontzorgende rol op zich te nemen. Door altijd met één been in de belevingswereld van de doelgroep te blijven, en met één been in de bubbel van de opdrachtgever, wordt de juiste kennis op de meest effectieve manier doorvertaald naar daar waar het impact heeft.<br><br>Binnen Astrolads is Dave voor opdrachtgevers hoofdzakelijk actief als <strong>Communicatieadviseur</strong>. Vanuit deze rol helpt hij organisaties aan pakkende strategieën om interne en externe communicatie te optimaliseren, kennis om te zetten in beweging en dit te koppelen aan praktische middelen. Wat betreft bedrijfsmanagement van Astrolads richt Dave zich via HR & Operations op het creëren van een inspirerende werksfeer waar zelfontwikkeling centraal staat, zowel in de fysieke ruimte als bij de mensen. Van ontwikkelgesprekken met het team tot klusprojecten en van werving- en selectie tot kwaliteitsmanagement… Dave krijgt energie van een plek creëren (en behouden) waar iedereen zich thuis voelt, persoonlijk kan excelleren en waar levensplezier en een gevoel van waarde centraal staan. Naast dit alles is Dave ook een presentatietalent. Van live podium, tot video\'s en podcasts… Dave brengt luchtigheid waar het zwaar wordt, en maakt vanuit de complexiteit de praktische vertaalslag.',
    linkedin: 'https://www.linkedin.com/in/davenickverwey/',
    buiten: 'Dave wordt vooral gelukkig van actief bezig zijn, zowel fysiek als mentaal. Dit krijgt buiten Astrolads voornamelijk vorm in zijn cabaretduo <strong>Joey & Dave</strong>. Samen met zijn broer stond hij in de finale van Cameretten in 2022, en sindsdien toert hij met eigen avondvullende theaterprogramma\'s door heel het land.<br><br>En hoe ontspant iemand die het liefst altijd druk bezig is? Door voor de lol 42.2 kilometer te rennen! Met inmiddels de derde marathon op de kalender, heeft Dave in het hardlopen een passie ontdekt waar hij energie uit put en lekker in kan \'nerden\'.<br><br>Als Dave zichzelf dan wel heel even de tijd gunt om op zijn achterwerk te zitten, doet hij dat het liefst tijdens het spelen van bordspellen of met een boek in de hand.',
    fotos: ['/images/team/dave-1.webp', '/images/team/dave-2.webp', '/images/team/dave-3.webp', '/images/team/dave-4.webp', '/images/team/dave-5.webp', '/images/team/dave-6.webp'],
    fotosPosities: ['center center', 'center center', 'center center', '30% center', 'center center', 'center center'],
    fotosBuiten: ['/images/team/dave-buiten-1.webp', '/images/team/dave-buiten-2.webp', '/images/team/dave-buiten-3.webp', '/images/team/dave-buiten-4.webp'],
    decoratie: { kleur: 'var(--orange)', top: '40px', right: '-120px', size: '480px' },
  },
};


const data = teamleden[slug as keyof typeof teamleden];
if (!data) return Astro.redirect('/over-ons');

// Genereer een SEO-geoptimaliseerde meta description
const bioKort = data.bio.split(/[.!?]/)[0].trim();
const metaDescription = data.naam + ', ' + data.rollen[0].toLowerCase() + ' bij Astrolads in Den Haag. ' + bioKort + '.';

const volgorde = [
  'luuk-van-ooijen',
  'floor-van-der-hoeven',
  'joey-meeuwenoord',
  'kylian-benna',
  'jelle-van-der-zanden',
  'dave-verwey',
  'philip-tjahjadi',
  'nick-mooijekind',
  'paulina-kacymirow',
  'bas-nieuwenhuijs',
  'doa-karasahin',
  'thijs-riep',
  'sude-kirlioglu',
  'zofia-michalak',
  'jamie-kuiper',
];

const andereTeamleden = volgorde
  .filter(s => s !== slug && teamleden[s as keyof typeof teamleden])
  .map(s => {
    const d = teamleden[s as keyof typeof teamleden];
    return { slug: s, naam: d.naam, foto: d.foto };
  });
---

<Layout
  title={data.naam}
  description={metaDescription}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": data.naam,
    "jobTitle": data.rollen[0],
    "description": data.bio,
    "image": `https://astrolads.com${data.foto}`,
    "url": `https://astrolads.com/team/${slug}`,
    "worksFor": {
      "@type": "Organization",
      "name": "Astrolads",
      "@id": "https://astrolads.com/#organization"
    },
    "knowsAbout": data.rollen,
    ...(data.linkedin ? { "sameAs": [data.linkedin] } : {}),
    "mainEntityOfPage": `https://astrolads.com/team/${slug}`
  })} />

  <div class="team-detail">
    <div class="deco-cirkel" aria-hidden="true" style={
      'background:' + data.decoratie.kleur + ';' +
      'width:' + data.decoratie.size + ';' +
      'height:' + data.decoratie.size + ';' +
      'top:' + (data.decoratie.top || 'auto') + ';' +
      'right:' + (data.decoratie.right || 'auto') + ';' +
      'bottom:' + (data.decoratie.bottom || 'auto') + ';' +
      'left:' + (data.decoratie.left || 'auto') + ';'
    }></div>
    <div class="section-inner">
      <Breadcrumb items={[
        { name: 'Over ons', url: '/over-ons' },
        { name: data.naam }
      ]} />

      <!-- Header -->
      <div class="team-header">
        <div class="team-header-left">
          <h1>{data.naam}</h1>
          <div class="rollen">
            {data.rollen.map(r => (
              <span class="rol-pill">{r}</span>
            ))}
          </div>
          <p class="team-bio">{data.bio}</p>
          {data.linkedin && (
            <a href={data.linkedin} class="linkedin-btn" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
          )}
        </div>
        <div class="team-header-img">
          <img src={data.foto} alt={data.naam + ' - ' + data.rollen[0] + ' bij Astrolads'} width="480" height="560" loading="eager" fetchpriority="high" decoding="sync" style={'object-position:' + (data.fotoPositie || 'center center')} />
        </div>
      </div>

      <!-- Duo-blok (alleen Jelle & Dave): tekst LINKS, fader RECHTS -->
      {data.duoBlok && (
        <div class="over-sectie duo-blok">
          <div class="over-tekst">
            <h2>{data.duoBlok.titel}</h2>
            <p>{data.duoBlok.tekst}</p>
          </div>
          <div class="over-fader" data-speed="4000">
            {data.duoBlok.fotos.map((f, i) => (
              <img
                src={f}
                alt={'Jelle en Dave foto ' + (i + 1)}
                width="480" height="560"
                loading="lazy"
                class:list={['fader-slide', { active: i === 0 }]}
              />
            ))}
            <div class="fader-dots">
              {data.duoBlok.fotos.map((_, i) => (
                <button class:list={['fader-dot', { active: i === 0 }]} data-index={i} aria-label={'Foto ' + (i + 1)}></button>
              ))}
            </div>
          </div>
        </div>
      )}

      <!-- Over sectie: fader LINKS, tekst RECHTS -->
      {data.bioLang && (
        <div class="over-sectie">
          {data.fotos.length > 0 && (
            <div class="over-fader" data-speed={data.faderSpeed || 4000}>
              {data.fotos.map((f, i) => (
                <img
                  src={f}
                  alt={data.naam + ' foto ' + (i + 1)}
                  width="480" height="560"
                  loading="lazy"
                  class:list={['fader-slide', { active: i === 0 }]}
                  style={data.fotosPosities && data.fotosPosities[i] ? 'object-position:' + data.fotosPosities[i] : ''}
                />
              ))}
              <div class="fader-dots">
                {data.fotos.map((_, i) => (
                  <button class:list={['fader-dot', { active: i === 0 }]} data-index={i} aria-label={'Foto ' + (i + 1)}></button>
                ))}
              </div>
            </div>
          )}
          <div class="over-tekst">
            <h2>Over {data.naam.split(' ')[0]}</h2>
            <p set:html={data.bioLang}></p>
          </div>
        </div>
      )}

      <!-- Buiten Astrolads: tekst LINKS, fader RECHTS -->
      <div class="over-sectie">
        <div class="over-tekst">
          <h2>Buiten Astrolads</h2>
          <p set:html={data.buiten}></p>
        </div>
        {data.fotosBuiten.length > 0 && (
          <div class="over-fader" data-speed={data.faderSpeedBuiten || data.faderSpeed || 4000}>
            {data.fotosBuiten.map((f, i) => (
              <img
                src={f}
                alt={data.naam + ' buiten Astrolads ' + (i + 1)}
                width="480" height="560"
                loading="lazy"
                class:list={['fader-slide', { active: i === 0 }]}
                style={data.fotosBuitenPosities && data.fotosBuitenPosities[i] ? 'object-position:' + data.fotosBuitenPosities[i] : ''}
              />
            ))}
            <div class="fader-dots">
              {data.fotosBuiten.map((_, i) => (
                <button class:list={['fader-dot', { active: i === 0 }]} data-index={i} aria-label={'Foto ' + (i + 1)}></button>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Ons team -->
      <div class="ons-team">
        <h2>Ons team</h2>
        <div class="team-grid" id="teamGrid">
          {andereTeamleden.map(lid => (
            <a href={'/team/' + lid.slug} class="team-card">
              <img src={lid.foto} alt={lid.naam} width="300" height="300" loading="lazy" />
              <div class="team-card-body">
                <h3>{lid.naam}</h3>
                <span class="btn-text-arrow" style="margin-top:12px">Lees meer</span>
              </div>
            </a>
          ))}
        </div>
        <div class="carousel-nav">
          <button class="carousel-btn" onclick="scrollOnsTeam(-1)" aria-label="Vorige">←</button>
          <button class="carousel-btn" onclick="scrollOnsTeam(1)" aria-label="Volgende">→</button>
        </div>
      </div>

    </div>
  </div>
</Layout>

<style>
  .team-detail { padding: 64px 0 96px; position: relative; overflow-x: clip; }

  .deco-cirkel {
    position: absolute;
    border-radius: 50%;
    z-index: 0; pointer-events: none;
  }

  .section-inner { position: relative; z-index: 1; }

  .team-header {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 64px; align-items: start; margin-bottom: 96px;
  }
  .team-header h1 { font-size: clamp(32px, 4vw, 52px); font-weight: 700; margin-bottom: 20px; }
  .rollen { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; }
  .rol-pill {
    font-size: 12px; background: var(--white);
    border-radius: 999px; padding: 5px 14px;
    border: 1px solid rgba(0,0,0,.12); color: var(--text);
  }
  .team-bio { color: var(--muted); line-height: 1.7; margin-bottom: 24px; font-size: 16px; }
  .linkedin-btn {
    display: inline-flex; align-items: center; gap: 8px;
    background: #0A66C2; color: #fff;
    text-decoration: none; font-size: 13px;
    border-radius: 999px; padding: 8px 18px;
    transition: opacity .2s;
  }
  .linkedin-btn:hover { opacity: .88; }
  .team-header-img img { width: 100%; border-radius: var(--radius); object-fit: cover; }

  .over-sectie {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: start; margin-bottom: 96px;
  }

  /* Duo-blok: wit blok met afgeronde hoeken */
  .duo-blok {
    background: var(--white);
    border-radius: var(--radius);
    padding: 56px;
    gap: 48px;
    align-items: center;
  }
  .duo-blok .over-fader {
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4/3;
  } 
  .over-tekst h2 { font-size: 32px; font-weight: 700; margin-bottom: 24px; }
  .over-tekst p { color: var(--muted); line-height: 1.8; font-size: 15px; }
  .over-tekst p strong { color: var(--text); font-weight: 700; }

  .over-fader {
    position: relative; border-radius: var(--radius);
    overflow: hidden; aspect-ratio: 4/5;
  }
  .fader-slide {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; opacity: 0;
    transition: opacity .8s ease;
  }
  .fader-slide.active { opacity: 1; }
  .fader-dots {
    position: absolute; bottom: 16px; left: 50%;
    transform: translateX(-50%);
    display: flex; gap: 8px; z-index: 2;
  }
  .fader-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(255,255,255,.5);
    border: none; cursor: pointer; transition: background .2s; padding: 0;
  }
  .fader-dot.active { background: #fff; }

  .ons-team { margin-top: 80px; }
  .ons-team h2 { font-size: 32px; font-weight: 700; margin-bottom: 32px; text-align: center; }
  .team-grid {
    display: flex; gap: 20px;
    overflow-x: auto; overflow-y: visible;
    padding: 8px 4px 32px;
    -ms-overflow-style: none; scrollbar-width: none;
  }
  .team-grid::-webkit-scrollbar { display: none; }
  .team-card {
    flex: 0 0 220px; background: var(--white);
    border-radius: var(--radius); overflow: hidden;
    text-decoration: none; color: inherit;
    transition: transform .2s, box-shadow .2s;
  }
  .team-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,.1);
  }
  .team-card img { width: 100%; height: 220px; object-fit: cover; }
  .team-card-body { padding: 16px; display: flex; flex-direction: column; }
  .team-card-body h3 { font-size: 15px; font-weight: 700; margin-bottom: 8px; }

  .carousel-nav { display: flex; gap: 12px; justify-content: flex-end; margin-top: 24px; }
  .carousel-btn {
    width: 44px; height: 44px; border-radius: 50%;
    border: 1.5px solid rgba(0,0,0,.2); background: transparent;
    cursor: pointer; font-size: 16px; transition: background .2s;
  }
  .carousel-btn:hover { background: var(--white); }

  @media (max-width: 768px) {
    .team-detail { padding: 32px 0 56px; }

    /* Decoratie-cirkel kleiner, hoger en achter de nav langs */
    .deco-cirkel {
      width: 280px !important;
      height: 280px !important;
      top: -150px !important;
      right: -100px !important;
      z-index: -1 !important;
    }

    /* Header: foto eerst, tekst eronder */
    .team-header {
      display: flex; flex-direction: column-reverse;
      gap: 28px;
      margin-bottom: 56px;
    }
    .team-header h1 {
      font-size: clamp(28px, 7vw, 36px);
      margin-bottom: 16px;
      line-height: 1.15;
    }
    .rollen { gap: 6px; margin-bottom: 18px; }
    .rol-pill { font-size: 11px; padding: 4px 12px; }
    .team-bio { font-size: 14px; line-height: 1.6; margin-bottom: 20px; }
    .linkedin-btn { font-size: 12px; padding: 7px 16px; }
    .team-header-img img {
      aspect-ratio: 4 / 3;
      height: auto;
      object-fit: cover;
      object-position: center 18% !important;
    }

    /* Over-secties: foto altijd boven, tekst eronder (forceer order ondanks DOM-volgorde) */
    .over-sectie {
      display: flex; flex-direction: column;
      gap: 24px;
      margin-bottom: 56px;
    }
    /* Duo-blok op mobile: compacter wit blok */
    .duo-blok {
      padding: 24px;
      gap: 20px;
    }
    .over-sectie .over-fader { order: -1; }
    .over-tekst h2 { font-size: 24px; margin-bottom: 16px; }
    .over-tekst p { font-size: 14px; line-height: 1.7; }
    .over-fader {
      aspect-ratio: 16 / 9;
      max-height: none;
      width: 100%;
      min-height: 200px;
    }
    .over-fader .fader-slide { object-position: center 30%; }
    

    /* Touch-target van fader-dots iets groter */
    .fader-dot { width: 10px; height: 10px; }

    /* Ons team: peek-scroll zoals homepage */
    .ons-team { margin-top: 48px; }
    .ons-team h2 { font-size: 24px; margin-bottom: 20px; text-align: left; }
    .team-grid {
      margin: 0 -20px;
      padding: 8px 20px 24px;
      gap: 12px;
    }
    .team-card { flex: 0 0 200px; }
    .team-card img { height: 200px; }
    .team-card-body { padding: 14px; }
    .team-card-body h3 { font-size: 14px; }

    /* Pijltjes verbergen op mobile, swipe is genoeg */
    .ons-team .carousel-nav { display: none; }
  }
</style>

<script>
function scrollOnsTeam(dir) {
    var el = document.getElementById('teamGrid');
    if (el) el.scrollBy({ left: dir * 240, behavior: 'smooth' });
  }
  window.scrollOnsTeam = scrollOnsTeam;


  document.querySelectorAll('.over-fader').forEach(function(fader) {
    var slides = fader.querySelectorAll('.fader-slide');
    var dots = fader.querySelectorAll('.fader-dot');
    var current = 0;
    var speed = parseInt(fader.getAttribute('data-speed')) || 4000;

    function goTo(index) {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      current = index;
      slides[current].classList.add('active');
      dots[current].classList.add('active');
    }

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        goTo(parseInt(dot.getAttribute('data-index')));
      });
    });

    if (slides.length > 1) {
      setInterval(function() {
        goTo((current + 1) % slides.length);
      }, speed);
    }
  });
</script>