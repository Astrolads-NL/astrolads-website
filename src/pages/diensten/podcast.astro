---
import Layout from '../../layouts/Layout.astro';

const covers = [
  '/images/diensten/podcast-cover-1.webp',
  '/images/diensten/podcast-cover-2.webp',
  '/images/diensten/podcast-cover-3.webp',
  '/images/diensten/podcast-cover-4.webp',
  '/images/diensten/podcast-cover-5.webp',
  '/images/diensten/podcast-cover-6.webp',
  '/images/diensten/podcast-cover-7.webp',
  '/images/diensten/podcast-cover-8.webp',
];
---

<Layout
  title="Podcast"
  description="Podcastproductie in onze studio aan de Grote Markt in Den Haag. Van concept en opname tot edit en distributie. Astrolads ontzorgt je volledig, van idee tot publicatie."
>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Podcastproductie",
    "provider": { "@type": "Organization", "name": "Astrolads", "@id": "https://astrolads.com/#organization" },
    "areaServed": { "@type": "Country", "name": "Netherlands" },
    "description": "Podcastproductie van concept tot oplevering. Opnames in onze eigen studio in Den Haag, inclusief edit, mixage en distributie.",
    "url": "https://astrolads.com/diensten/podcast"
  })} />

  <div class="dienst-page">
    <div class="section-inner">

      <!-- Header -->
      <div class="dienst-header">
        <div class="dienst-header-titel">
          <p class="section-label">Diensten</p>
          <h1>Podcast</h1>
        </div>
        <div class="dienst-header-img">
          <div class="header-slider">
            <img class="header-slide active" src="/images/diensten/podcast-slide-1.webp" alt="Astrolads podcaststudio" width="640" height="480" loading="eager" fetchpriority="high" decoding="sync" />
            <img class="header-slide" src="/images/diensten/podcast-slide-2.webp" alt="Astrolads podcastopname" width="640" height="480" loading="lazy" />
            <img class="header-slide pos-top" src="/images/diensten/podcast-slide-3.webp" alt="Astrolads podcast op locatie" width="640" height="480" loading="lazy" />
          </div>
        </div>
        <div class="dienst-header-tekst">
          <p class="dienst-intro">Geen enkele andere mediavorm grijpt zo lang de aandacht van jouw doelgroep als een podcast. Gehuld in entertainment, een ideale vorm voor verbinding op inhoud.</p>
          <p class="dienst-intro">Het belangrijkste voordeel van een podcast is dat het naadloos aansluit op de levensstijl van de luisteraar. Men hoeft er niet voor te gaan zitten of te stoppen met wat ze op dat moment aan het doen zijn, maar luisteren het lekker weg tijdens het werk, tijdens het koken of in de auto. Om deze reden is het ook belangrijk dat een podcast niet enkel om de inhoud draait, maar ook om het zijn van een vermakelijk format. Zodat je zowel bij behoefte aan verdieping óf juist ontspanning, de doelgroep bedient.</p>
          <a href="/contact" class="btn-orange">Kennismaken</a>
        </div>
      </div>

      <!-- Slider links, tekst rechts -->
      <div class="podcast-tekst-sectie">
        <div class="podcast-slider">
          <img class="podcast-slide active" src="/images/diensten/podcast-sfeer-1.webp" alt="Astrolads podcastopname" loading="lazy" />
          <img class="podcast-slide" src="/images/diensten/podcast-sfeer-2.webp" alt="Astrolads podcaststudio" loading="lazy" />
          <img class="podcast-slide" src="/images/diensten/podcast-sfeer-3.webp" alt="Astrolads podcast op locatie" loading="lazy" />
          <img class="podcast-slide pos-top" src="/images/diensten/podcast-sfeer-4.webp" alt="Astrolads podcast op locatie" loading="lazy" />
          <img class="podcast-slide pos-top" src="/images/diensten/podcast-sfeer-5.webp" alt="Astrolads podcast op locatie" loading="lazy" />
          <div class="podcast-dots">
            <button class="podcast-dot active" data-index="0"></button>
            <button class="podcast-dot" data-index="1"></button>
            <button class="podcast-dot" data-index="2"></button>
            <button class="podcast-dot" data-index="3"></button>
            <button class="podcast-dot" data-index="4"></button>
          </div>
        </div>
        <div class="podcast-tekst">
          <p>Naast het opnemen en publiceren van de audio-content, is het ook mogelijk om de volledige afleveringen op te nemen en als video content in te zetten. Ook leent het zich voor het maken van verticale video's voor op je social media kanalen. Zowel als losstaande content, of om nieuwe luisteraars aan te trekken.</p>
          <p>Wij bieden twee opties voor het opnemen van podcasts. Allereerst bij ons in de Astrolads Studio, waar alles al klaar staat om geruisloos jouw podcast op te nemen. Van studio-aankleding tot live camera switching, alles is mogelijk. De tweede optie is het opnemen van een podcast op locatie, soms gewenst zodat jouw gasten minder ver hoeven te reizen, of omdat de gewenste omgeving (binnen óf buiten) aansluit bij het thema van de aflevering.</p>
          <p>Van idee tot publicatie op alle bekende podcastplatformen, wij ontzorgen je volledig met de opzet van jouw unieke podcast-reeks, cover, draaiboek, planning, opname, edit en publicatie.</p>
        </div>
      </div>

      <!-- Covers -->
      <div class="covers-sectie">
        <h2>Onze producties</h2>
        <div class="covers-grid">
          {covers.map(c => (
            <div class="cover-item">
              <img src={c} alt="Podcast cover door Astrolads" loading="lazy" />
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="dienst-cta">
        <h2>Klaar om aan de slag te gaan?</h2>
        <p>Benieuwd wat een podcast voor jouw organisatie kan betekenen? We denken graag met je mee.</p>
        <a href="/contact" class="btn-orange">Kennismaken</a>
      </div>

    </div>
  </div>
</Layout>

<style>
  .dienst-page { padding: 64px 0 96px; }

  .dienst-header {
    display: grid; grid-template-columns: 1fr 1fr;
    grid-template-areas:
      "titel slider"
      "tekst slider";
    gap: 0 80px; align-items: start;
    margin-bottom: 96px;
  }
  .dienst-header-titel { grid-area: titel; align-self: end; padding-bottom: 16px; }
  .dienst-header-img { grid-area: slider; align-self: center; }
  .dienst-header-tekst { grid-area: tekst; }
  .dienst-header-titel h1 {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 700; line-height: 1.1;
    margin-bottom: 0;
  }
  .dienst-intro {
    font-size: 17px; color: var(--muted);
    line-height: 1.7; margin-bottom: 24px;
  }
  .dienst-intro + .dienst-intro { margin-top: -8px; margin-bottom: 32px; }
  .header-slider { position: relative; height: 460px; border-radius: var(--radius); overflow: hidden; }
  .header-slide {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; opacity: 0;
    transition: opacity 1s ease;
  }
  .header-slide.active { opacity: 1; }
  .pos-top { object-position: center 15% !important; }

  /* Tekst + slider */
  .podcast-tekst-sectie {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: start;
    margin-bottom: 96px;
  }
  .podcast-slider {
    position: relative; border-radius: var(--radius);
    overflow: hidden; height: 440px;
  }
  .podcast-slide {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; opacity: 0;
    transition: opacity .8s ease;
  }
  .podcast-slide.active { opacity: 1; }
  .podcast-dots {
    position: absolute; bottom: 16px; left: 50%;
    transform: translateX(-50%);
    display: flex; gap: 8px; z-index: 2;
  }
  .podcast-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(255,255,255,.5);
    border: none; cursor: pointer; padding: 0;
    transition: background .2s;
  }
  .podcast-dot.active { background: #fff; }
  .podcast-tekst { display: flex; flex-direction: column; gap: 24px; }
  .podcast-tekst p { color: var(--muted); line-height: 1.9; font-size: 16px; }
  .podcast-tekst strong { color: var(--text); font-weight: 700; }

  /* Covers */
  .covers-sectie { margin-bottom: 96px; }
  .covers-sectie h2 { font-size: 32px; font-weight: 700; margin-bottom: 40px; text-align: center; }
  .covers-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .cover-item {
    aspect-ratio: 1;
    border-radius: 16px;
    overflow: hidden;
    transition: transform .2s, box-shadow .2s;
  }
  .cover-item:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,.12); }
  .cover-item img { width: 100%; height: 100%; object-fit: cover; }

  /* CTA */
  .dienst-cta {
    text-align: center;
    background: var(--navy);
    border-radius: var(--radius);
    padding: 64px;
    color: #fff;
  }
  .dienst-cta h2 { font-size: 32px; font-weight: 700; margin-bottom: 16px; }
  .dienst-cta p { opacity: .8; margin-bottom: 32px; font-size: 16px; }

  @media (max-width: 768px) {
    .dienst-page { padding: 32px 0 56px; }

    /* Header: titel → slider → tekst → knop */
    .dienst-header {
      display: flex !important;
      flex-direction: column !important;
      grid-template-areas: none !important;
      grid-template-columns: 1fr !important;
      gap: 20px;
      margin-bottom: 56px;
    }
    .dienst-header-titel,
    .dienst-header-img,
    .dienst-header-tekst {
      grid-area: auto !important;
      align-self: auto !important;
      width: 100%;
    }
    .dienst-header-titel {
      padding-bottom: 0;
    }
    .dienst-header-titel h1 {
      font-size: clamp(28px, 7vw, 36px);
      line-height: 1.15;
      margin-bottom: 0;
    }
    .dienst-intro {
      font-size: 14px;
      line-height: 1.7;
      margin-bottom: 16px;
    }
    .dienst-intro + .dienst-intro { margin-top: -4px; margin-bottom: 20px; }
    .header-slider {
      height: auto !important;
      aspect-ratio: 16 / 9;
      width: 100%;
      position: relative;
    }
    .header-slider .header-slide {
      position: absolute !important;
      inset: 0 !important;
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
    }

    /* Tekst-met-sfeer-slider: slider eerst, dan tekst */
    .podcast-tekst-sectie {
      display: flex; flex-direction: column;
      gap: 20px;
      margin-bottom: 56px;
    }
    .podcast-tekst-sectie .podcast-slider { order: -1; }
    .podcast-slider {
      height: auto !important;
      aspect-ratio: 16 / 9;
      max-height: 240px;
      width: 100%;
      position: relative;
    }
    .podcast-slider .podcast-slide {
      position: absolute !important;
      inset: 0 !important;
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
    }
    .podcast-dot { width: 10px; height: 10px; }
    .podcast-tekst { gap: 16px; }
    .podcast-tekst p {
      font-size: 14px;
      line-height: 1.7;
    }

    /* Covers: 3 kolommen op mobile */
    .covers-sectie { margin-bottom: 56px; }
    .covers-sectie h2 {
      font-size: 24px;
      margin-bottom: 24px;
    }
    .covers-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    /* CTA compacter */
    .dienst-cta {
      padding: 36px 24px;
    }
    .dienst-cta h2 {
      font-size: 22px;
      line-height: 1.3;
      margin-bottom: 12px;
    }
    .dienst-cta p {
      font-size: 14px;
      margin-bottom: 24px;
    }
  }
</style>

<script>
  var podcastSlides = document.querySelectorAll('.podcast-slide');
  var podcastDots = document.querySelectorAll('.podcast-dot');
  var podcastCurrent = 0;
  function podcastGoTo(i) {
    podcastSlides[podcastCurrent].classList.remove('active');
    podcastDots[podcastCurrent].classList.remove('active');
    podcastCurrent = i;
    podcastSlides[podcastCurrent].classList.add('active');
    podcastDots[podcastCurrent].classList.add('active');
  }
  podcastDots.forEach(function(dot) {
    dot.addEventListener('click', function() {
      podcastGoTo(parseInt(dot.getAttribute('data-index')));
    });
  });
  setInterval(function() { podcastGoTo((podcastCurrent + 1) % podcastSlides.length); }, 4000);

  var headerSlides = document.querySelectorAll('.header-slide');
  var headerCurrent = 0;
  setInterval(function() {
    headerSlides[headerCurrent].classList.remove('active');
    headerCurrent = (headerCurrent + 1) % headerSlides.length;
    headerSlides[headerCurrent].classList.add('active');
  }, 4000);
</script>