---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const vormen = [
  {
    titel: 'Evenementfotografie',
    tekst: 'Evenementen zijn vaak een hele klus om op te zetten. Des te belangrijker dat je op de dag zelf alles in mooi stilstaand beeld vastlegt. Zo neem je de bezoekers in een namailen of op social media nogmaals mee in jouw event. Daarnaast zijn foto\'s van jouw event ook goed inzetbaar als marketingmateriaal voor een eventuele volgende editie. Wij zorgen ervoor dat jij de beste plaatjes hebt van het totale evenement, bezoekers, sprekers, aankleding en de borrel. Vaak wil je op dezelfde avond van het evenement, of de ochtend daarna, al gelijk wat delen. Daarom zorgen wij dat je op de dag zelf direct enkele foto\'s ontvangt voor een nieuwsbrief of social media post!',
   fotos: [
      '/images/diensten/fotografie-evenementen-1.webp',
      '/images/diensten/fotografie-evenementen-2.webp',
      '/images/diensten/fotografie-evenementen-3.webp',
      '/images/diensten/fotografie-evenementen-4.webp',
      '/images/diensten/fotografie-evenementen-5.webp',
      '/images/diensten/fotografie-evenementen-6.webp',
      '/images/diensten/fotografie-evenementen-7.webp',
      '/images/diensten/fotografie-evenementen-8.webp',
      '/images/diensten/fotografie-evenementen-9.webp',
      '/images/diensten/fotografie-evenementen-10.webp',
    ],
  },
  {
    titel: 'Portretfotografie',
    tekst: 'Goede foto\'s van jouw team/collega\'s zijn multi-inzetbaar. Van een teampagina op de website en overeenstemmende LinkedIn-profielfoto\'s, tot de handtekening onderaan de mail… wij zorgen dat iedereen er goed opstaat. Wij maken portretfoto\'s bij ons in de fotostudio, maar komen ook met alle liefde naar jouw werklocatie of mooie buitenomgeving om de beste plaatjes te schieten!',
    fotos: [
      '/images/diensten/fotografie-portret-1.webp',
      '/images/diensten/fotografie-portret-2.webp',
      '/images/diensten/fotografie-portret-3.webp',
      '/images/diensten/fotografie-portret-4.webp',
      '/images/diensten/fotografie-portret-5.webp',
      '/images/diensten/fotografie-portret-6.webp',
      '/images/diensten/fotografie-portret-7.webp',
    ],
  },
];
---

<Layout
  title="Fotografie"
  description="Professionele fotografie voor events, portretten en bedrijfsuitingen. Astrolads zorgt voor een uniforme beeldbank en sfeerverslag van jouw merk of evenement."
>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Fotografie",
    "provider": { "@type": "Organization", "name": "Astrolads", "@id": "https://astrolads.com/#organization" },
    "areaServed": { "@type": "Country", "name": "Netherlands" },
    "description": "Professionele fotografie voor evenementen, portretten en bedrijfsuitingen. Van eventfotografie tot uniforme teamportretten.",
    "url": "https://astrolads.com/diensten/fotografie"
  })} />

  <div class="dienst-page">
    <div class="section-inner">
      <Breadcrumb items={[
        { name: 'Diensten', url: '/diensten' },
        { name: 'Fotografie' }
      ]} />

      <!-- Header -->
      <div class="dienst-header">
        <div class="dienst-header-tekst">
          <p class="section-label">Diensten</p>
          <h1>Fotografie</h1>
          <p class="dienst-intro">Een goed beeld zegt meer dan 1000 woorden. Met de juiste foto's zet je jezelf (online) in de schijnwerpers en heb je een beeldbank voor toekomstige communicatie-uitingen. Elke website, nieuwsbrief of LinkedIn-pagina wordt namelijk aantrekkelijker als je er mooi versterkend beeld bij gebruikt. Onze fotografen zorgen voor de meest representatieve portretfoto's en/of vangen de sfeer van jouw event in stilstaand beeld.</p>
          <a href="/contact" class="btn-orange">Kennismaken</a>
        </div>
       <div class="dienst-header-img">
          <img src="/images/diensten/fotografie-slide-1.webp" alt="Astrolads fotografie" width="640" height="480" loading="eager" fetchpriority="high" decoding="sync" />
        </div>
      </div>

      <!-- Quote -->
      <div class="dienst-quote-wrap">
        <div class="dienst-quote">
          <span class="quote-icon">&ldquo;</span>
          <blockquote>Heel strakke en goede content met een minimale briefing!</blockquote>
          <img src="/images/diensten/quotes/stephan-bredewold.webp" alt="Stephan Bredewold" class="quote-foto" />
        </div>
        <p class="quote-naam">Stephan Bredewold</p>
      </div>

      <!-- Vormen -->
      <div class="dienst-vormen">
        <h2 class="vormen-titel">Wat kunnen we voor je vastleggen?</h2>
        <div class="vormen-grid">
          {vormen.map((v, i) => (
            <div class:list={['vorm-sectie', { flip: i % 2 !== 0 }]}>
              <div class="vorm-img">
                {'fotos' in v ? (
                  <div class="foto-slider">
                    {v.fotos.map((f, j) => (
                      <img
                        src={f} alt={v.titel + ' door Astrolads'}
                        width="600" height="400" loading="lazy"
                        class:list={['foto-slide', { active: j === 0 }]}
                      />
                    ))}
                    <div class="foto-dots">
                      {v.fotos.map((_, j) => (
                        <button class:list={['foto-dot', { active: j === 0 }]} data-index={j} aria-label={'Foto ' + (j + 1)}></button>
                      ))}
                    </div>
                  </div>
                ) : (
                  <img src={v.img} alt={v.titel + ' door Astrolads'} width="600" height="400" loading="lazy" />
                )}
              </div>
              <div class="vorm-tekst">
                <h3>{v.titel}</h3>
                <p>{v.tekst}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="dienst-cta">
        <h2>Klaar om aan de slag te gaan?</h2>
        <p>Benieuwd wat fotografie voor jouw organisatie kan betekenen? We denken graag met je mee.</p>
        <a href="/contact" class="btn-orange">Kennismaken</a>
      </div>

    </div>
  </div>
</Layout>

<style>
  .dienst-page { padding: 64px 0 96px; }

  .dienst-header {
    display: grid; grid-template-columns: 1fr 1fr;
    grid-template-areas:
      "titel slider"
      "tekst slider";
    gap: 0 80px; align-items: start;
    margin-bottom: 120px;
  }
  .dienst-header-titel { grid-area: titel; align-self: end; padding-bottom: 16px; }
  .dienst-header-img { grid-area: slider; align-self: center; }
  .dienst-header-tekst { grid-area: tekst; }
  .dienst-header-tekst h1 {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 700; line-height: 1.1;
    margin-bottom: 24px;
  }
  .dienst-intro {
    font-size: 17px; color: var(--muted);
    line-height: 1.7; margin-bottom: 32px;
  }
  .dienst-header-img img {
    width: 100%; border-radius: var(--radius);
    object-fit: cover; height: 460px;
  }

  .vormen-titel {
    font-size: 32px; font-weight: 700;
    margin-bottom: 64px; text-align: center;
  }

  .vorm-sectie {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: start;
    margin-bottom: 120px;
  }
  .vorm-sectie.flip .vorm-img { order: 2; }
  .vorm-sectie.flip .vorm-tekst { order: 1; }
  .vorm-img img { width: 100%; border-radius: var(--radius); object-fit: cover; height: 320px; }
  .foto-slider {
    position: relative; border-radius: var(--radius);
    overflow: hidden; aspect-ratio: 3/2;
  }
  .foto-slide {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; opacity: 0;
    transition: opacity .8s ease;
  }
  .foto-slide.active { opacity: 1; }
  .foto-dots {
    position: absolute; bottom: 16px; left: 50%;
    transform: translateX(-50%);
    display: flex; gap: 8px; z-index: 2;
  }
  .foto-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(255,255,255,.5);
    border: none; cursor: pointer; padding: 0;
    transition: background .2s;
  }
  .foto-dot.active { background: #fff; }
  .vorm-tekst h3 { font-size: 28px; font-weight: 700; margin-bottom: 16px; }
  .vorm-tekst p { color: var(--muted); line-height: 1.8; font-size: 15px; }

  .dienst-cta {
    text-align: center;
    background: var(--navy);
    border-radius: var(--radius);
    padding: 64px;
    color: #fff;
  }
  .dienst-cta h2 { font-size: 32px; font-weight: 700; margin-bottom: 16px; }
  .dienst-cta p { opacity: .8; margin-bottom: 32px; font-size: 16px; }

  /* Dienst Quote Block (mobile only) */
  .dienst-quote-wrap {
    display: none;
    position: relative;
    margin: 64px 0 96px;
  }
  .dienst-quote {
    background: var(--navy); color: #fff;
    border-radius: var(--radius); padding: 20px 28px;
    position: relative; overflow: visible;
  }
  .dienst-quote .quote-icon {
    font-size: 48px; color: var(--orange);
    font-family: Georgia, serif; line-height: 0.7;
    display: block; margin-bottom: 0; font-style: normal;
  }
  .dienst-quote blockquote {
    font-size: 16px; line-height: 1.5; font-weight: 400;
    padding-right: 100px;
  }
  .dienst-quote-wrap .quote-naam {
    font-size: 15px; color: var(--navy);
    font-weight: 700;
    margin-top: 16px; padding-right: 180px;
    text-align: right;
  }
  .dienst-quote .quote-foto {
    position: absolute;
    bottom: -80px; right: -20px;
    width: 160px; height: 160px;
    border-radius: 50%; object-fit: cover;
    border: 4px solid var(--bg);
  }

  @media (max-width: 768px) {
    .dienst-quote-wrap {
      display: block;
      margin: 40px 0 80px;
    }
    .dienst-quote { padding: 20px 24px; }
    .dienst-quote blockquote {
      font-size: 14px;
      line-height: 1.5;
      padding-right: 0;
    }
    .dienst-quote .quote-icon { font-size: 36px; margin-bottom: -10px; }
    .dienst-quote .quote-foto {
      width: 90px; height: 90px;
      bottom: -55px; right: -12px;
      border-width: 3px;
    }
    .dienst-quote-wrap .quote-naam {
      font-size: 14px;
      margin-top: 10px;
      padding-right: 90px;
      text-align: right;
    }
  }

  @media (max-width: 768px) {
    .dienst-page { padding: 32px 0 56px; }

    /* Header: titel → slider → tekst → knop */
    .dienst-header {
      display: flex !important;
      flex-direction: column !important;
      grid-template-areas: none !important;
      grid-template-columns: 1fr !important;
      gap: 20px;
      margin-bottom: 56px;
    }
    .dienst-header-titel,
    .dienst-header-img,
    .dienst-header-tekst {
      grid-area: auto !important;
      align-self: auto !important;
      width: 100%;
    }
    .dienst-header-titel {
      padding-bottom: 0;
    }
    .dienst-header-titel h1 {
      font-size: clamp(28px, 7vw, 36px);
      line-height: 1.15;
      margin-bottom: 0;
    }
    .dienst-intro {
      font-size: 14px;
      line-height: 1.7;
      margin-bottom: 20px;
    }
    .dienst-header-img {
      width: 100%;
    }
    .dienst-header-img img {
      width: 100%;
      height: auto;
      aspect-ratio: 16 / 9;
    }

    /* Vormen-titel */
    .vormen-titel {
      font-size: 24px;
      margin-bottom: 32px;
    }

    /* Vorm-secties: titel boven, foto, dan tekst */
    .vorm-sectie {
      display: flex; flex-direction: column;
      gap: 16px;
      margin-bottom: 48px;
    }
    .vorm-sectie .vorm-img { order: 2; }
    .vorm-sectie .vorm-tekst { order: 1; display: contents; }
    .vorm-sectie .vorm-tekst h3 { order: 1; }
    .vorm-sectie .vorm-tekst p { order: 3; }
    .vorm-sectie.flip .vorm-img { order: 2; }
    .vorm-img { width: 100%; }
    .foto-slider {
      aspect-ratio: 16 / 9 !important;
      width: 100%;
      height: auto !important;
      position: relative;
    }
    .foto-slider .foto-slide {
      position: absolute !important;
      inset: 0 !important;
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
    }
    .foto-dot { width: 10px; height: 10px; }
    .vorm-tekst h3 {
      font-size: 20px;
      margin-bottom: 0;
    }
    .vorm-tekst p {
      font-size: 14px;
      line-height: 1.7;
    }

    /* CTA compacter */
    .dienst-cta {
      padding: 36px 24px;
    }
    .dienst-cta h2 {
      font-size: 22px;
      line-height: 1.3;
      margin-bottom: 12px;
    }
    .dienst-cta p {
      font-size: 14px;
      margin-bottom: 24px;
    }
  }
</style>

<script>
  document.querySelectorAll('.foto-slider').forEach(function(slider, sliderIndex) {
    var slides = slider.querySelectorAll('.foto-slide');
    var dots = slider.querySelectorAll('.foto-dot');
    var current = 0;
    var interval = sliderIndex === 0 ? 3000 : 4000;
    function goTo(i) {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      current = i;
      slides[current].classList.add('active');
      dots[current].classList.add('active');
    }
    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        goTo(parseInt(dot.getAttribute('data-index')));
      });
    });
    if (slides.length > 1) {
      setInterval(function() { goTo((current + 1) % slides.length); }, interval);
    }
  });

 
</script>