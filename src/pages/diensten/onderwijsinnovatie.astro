---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const pijlers = [
  {
    slug: 'studentenmediateams',
    titel: 'Studentenmediateams',
    intro: 'Om scholen zowel te helpen met talentontwikkeling als met een digitale mediastrategie, helpt Astrolads meerdere onderwijsinstellingen met het opstarten en begeleiden van een studentenmediateam. Dit is een groep leerlingen of studenten die (tijdelijk) een mediateam vormen om voor de eigen opleiding digitale mediaproducties te maken. Leerlingen die hier vanuit intrinsieke motivatie voor kiezen worden zo gemotiveerd en geactiveerd om hun talenten te ontwikkelen.',
    fotos: [
      '/images/diensten/onderwijs-mediateam-1.webp',
      '/images/diensten/onderwijs-mediateam-2.webp',
      '/images/diensten/onderwijs-mediateam-3.webp',
    ],
    cases: [
      {
        titel: 'Spread',
        partnerLogo: '/images/onderwijs/mborijnland.webp',
        partnerNaam: 'mboRijnland',
        tekst: 'In samenwerking met mboRijnland begeleidt Astrolads elk half jaar een groep studenten vanuit de opleiding mediavormgeving in Leiden. Vier tot zes mediastudenten vormen samen het studentenmediateam Spread: vijf dagen per week, fulltime begeleid door experts vanuit Astrolads, en producerend voor de regio. In een half jaar leveren ze meer dan 100 mediaproducten op en doen ze naast productie-ervaring ook kennis op over de praktische kant van de markt. Denk aan klantcontact, revisies, deadlines en planning.',
      },
      {
        titel: 'Klaaswaal Mediateam',
        partnerLogo: '/images/onderwijs/yuverta.webp',
        partnerNaam: 'Yuverta',
        tekst: 'Op de Yuverta-locatie Klaaswaal, een middelbare school georiënteerd op de groene sector, heeft Astrolads een studentenmediateam opgestart. Dit team van 4 tot 6 leerlingen maakt na een workshop vanuit Astrolads mediaproducties voor de school. Ze worden op oproepbasis ingezet: van bedrijfsbezoeken om baankansen in beeld te brengen, tot interviews op opendagen om bezoekers te vragen wat hen aantrekt tot Yuverta. Alle draaidagen worden begeleid door experts vanuit Astrolads. De producties verschijnen op de online kanalen en helpen bij de digitale mediastrategie en werving van nieuwe leerlingen.',
      },
    ],
  },
  {
    slug: 'praktische-leertrajecten',
    titel: 'Praktische leertrajecten',
    intro: 'Astrolads zet zich intensief in voor unieke praktische leertrajecten. Groepen studenten gaan aan de slag met een praktijkopdracht, begeleid door Astrolads. Dit varieert van eenmalige onderzoeken tot langdurige trajecten.',
    fotos: [
      '/images/diensten/onderwijs-leertraject-1.webp',
      '/images/diensten/onderwijs-leertraject-2.webp',
      '/images/diensten/onderwijs-leertraject-3.webp',
    ],
    cases: [
      {
        titel: 'Innovative Student Team',
        partnerLogo: '/images/onderwijs/tu-ecomotive.webp',
        partnerNaam: 'TU/Ecomotive',
        tekst: 'Studenten van TU/Eindhoven en de omliggende omgeving kunnen ervoor kiezen een tussenjaar te nemen waarin ze zich aanhaken bij het studententeam van TU/Ecomotive: 15 tot 30 studenten die zich een jaar lang focussen op het bouwen van een duurzame conceptauto. Al 10 jaar lang worden auto\'s als ZEM (met co2-filter), LUCA (gemaakt van gerecycled materiaal) en ETERNA (een modulaire auto) door studenten bedacht, ontworpen, gebouwd en geshowcased over de hele wereld. Astrolads is dé mediapartner van het team: van presentatievideo\'s en livestreams tot content- en fotografieworkshops, en tijdens de jaarlijkse promotie-wereldtour reist een Astrolads-expert mee als content creator.',
      },
      {
        titel: 'Creative Agency',
        partnerLogo: '/images/onderwijs/inholland.webp',
        partnerNaam: 'Inholland',
        tekst: 'Vanuit Inholland vormt een groep studenten elk half jaar een creative agency met de opdracht een praktijkopdracht uit te voeren. Astrolads is (naast onder andere Gemeente Den Haag en Pathé Bioscopen) een van de partners die hieraan meewerken. Vanuit Astrolads krijgt de groep een onderzoeksvraag mee, waar ze een half jaar mee aan de slag gaan. Met regelmaat rapporteren ze de voortgang en obstakels die ze tegenkomen. Uiteindelijk leveren ze een adviesrapport op en krijgen ze van zowel Inholland Den Haag als Astrolads een beoordeling.',
      },
    ],
  },
  {
    slug: 'loopbaanbegeleiding',
    titel: 'Loopbaanbegeleiding',
    intro: 'Word ik loodgieter, net als m\'n vader? Neem ik een tussenjaar en ga ik reizen? Of ga ik toch die kappersopleiding doen die me zo leuk lijkt? Naast intensieve mediabegeleiding verzorgt Astrolads ook op maat gemaakte loopbaanbegeleiding voor middelbare scholieren.',
    fotos: [
      '/images/diensten/onderwijs-loopbaan-1.webp',
      '/images/diensten/onderwijs-loopbaan-2.webp',
      '/images/diensten/onderwijs-loopbaan-3.webp',
    ],
    cases: [
      {
        titel: 'Snuffelstage',
        partnerLogo: '/images/onderwijs/jinc.webp',
        partnerNaam: 'JINC',
        tekst: 'Steeds meer jongeren lopen na de middelbare school vast in tussenjaren of vallen in het eerste studiejaar al uit door een verkeerde studiekeuze. Hierin speelt Astrolads graag een rol en zet zich daarom vrijwillig in als loopbaanbegeleider voor een groep vmbo-leerlingen op een Yuverta-locatie in Den Haag. Experts vanuit Astrolads begeleiden hier individueel verschillende leerlingen in hun derde schooljaar, om zo een beter beeld te krijgen van hun talenten en daarmee een passende vervolgstudie te kunnen kiezen.',
      },
    ],
  },
];
---

<Layout
  title="Onderwijsinnovatie"
  description="Onderwijsinnovatie door Astrolads. Studentenmediateams, praktische leertrajecten en loopbaanbegeleiding, op maat per onderwijsinstelling en doelgroep."
  image="/images/og/diensten/onderwijsinnovatie.jpg"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Onderwijsinnovatie",
    "provider": { "@type": "Organization", "name": "Astrolads", "@id": "https://astrolads.com/#organization" },
    "areaServed": { "@type": "Country", "name": "Netherlands" },
    "description": "Samenwerking met onderwijsinstellingen op het gebied van studentenmediateams, praktische leertrajecten en loopbaanbegeleiding. Op maat per doelgroep en onderwijsinstelling.",
    "url": "https://astrolads.com/diensten/onderwijsinnovatie"
  })} />

  <div class="dienst-page">
    <div class="section-inner">
      <Breadcrumb items={[
        { name: 'Diensten', url: '/diensten' },
        { name: 'Onderwijs Innovatie' }
      ]} />

      <!-- Header -->
      <div class="dienst-header">
        <div class="dienst-header-tekst">
          <p class="section-label">Diensten</p>
          <h1>Onderwijsinnovatie</h1>
          <p class="dienst-intro">Astrolads werkt innig samen met verschillende onderwijsinstellingen. Waar de kracht van het onderwijs ligt in het overbrengen van theoretische kennis, biedt Astrolads vooral ervaring, opdrachten en begeleiding vanuit de praktijk. Van mediateams tot praktische leertrajecten en loopbaanbegeleiding, altijd op maat per doelgroep en wens vanuit de onderwijsinstelling.</p>
          <a href="/contact" class="btn-orange">Kennismaken</a>
        </div>
        <div class="dienst-header-img">
          <img src="/images/diensten/onderwijs-header.webp" alt="Astrolads onderwijsinnovatie" width="640" height="460" loading="eager" fetchpriority="high" decoding="sync" />
        </div>
      </div>

      <!-- Pijlers -->
      <div class="onderwijs-pijlers">
        {pijlers.map((p, i) => (
          <section class="pijler-blok" id={p.slug}>
            <!-- Pijler header: tekst links, foto rechts -->
            <div class="pijler-top">
              <div class="pijler-tekst">
                <h2>{p.titel}</h2>
                <p class="pijler-intro">{p.intro}</p>
              </div>
              <div class="pijler-img">
                <div class="pijler-fader" data-fader>
                  {p.fotos.map((f, idx) => (
                    <img src={f} alt={p.titel + ' foto ' + (idx + 1)} class:list={['fader-slide', { active: idx === 0 }]} loading="lazy" />
                  ))}
                  <div class="fader-dots">
                    {p.fotos.map((_, idx) => (
                      <button class:list={['fader-dot', { active: idx === 0 }]} data-index={idx} aria-label={'Foto ' + (idx + 1)}></button>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            <!-- Cases naast elkaar -->
            <div class:list={['cases-grid', { single: p.cases.length === 1 }]}>
              {p.cases.map(c => (
                <article class="case-kaart">
                  <div class="case-head">
                    <h3>{c.titel}</h3>
                    <img src={c.partnerLogo} alt={c.partnerNaam + ' logo'} class="case-logo" loading="lazy" />
                  </div>
                  <p>{c.tekst}</p>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>

      <!-- CTA -->
      <div class="dienst-cta">
        <h2>Samenwerken aan onderwijsinnovatie?</h2>
        <p>Ben jij verbonden aan een onderwijsinstelling en zie je kansen voor samenwerking? We denken graag met je mee.</p>
        <a href="/contact" class="btn-orange">Kennismaken</a>
      </div>

    </div>
  </div>
</Layout>

<style>
  .dienst-page { padding: 64px 0 96px; }

  .dienst-header {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: center;
    margin-bottom: 120px;
  }
  .dienst-header-tekst h1 {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 700; line-height: 1.1;
    margin-bottom: 24px;
  }
  .dienst-intro {
    font-size: 17px; color: var(--muted);
    line-height: 1.7; margin-bottom: 32px;
  }
  .dienst-header-img img {
    width: 100%; height: 460px;
    border-radius: var(--radius);
    object-fit: cover;
  }

  .onderwijs-pijlers { margin-bottom: 96px; }
  .pijler-blok { margin-bottom: 120px; }

  .pijler-top {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, calc(50% - 12px));
    gap: 24px;
    align-items: center;
    margin-bottom: 24px;
  }

  .pijler-fader {
    position: relative;
    aspect-ratio: 16/10;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--white);
  }
  .fader-slide {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; opacity: 0;
    transition: opacity .8s ease;
  }
  .fader-slide.active { opacity: 1; }
  .fader-dots {
    position: absolute; bottom: 16px; left: 50%;
    transform: translateX(-50%);
    display: flex; gap: 8px; z-index: 2;
  }
  .fader-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(255,255,255,.5);
    border: none; cursor: pointer; transition: background .2s; padding: 0;
  }
  .fader-dot.active { background: #fff; }

  
  .pijler-tekst h2 {
    font-size: clamp(28px, 3vw, 36px);
    font-weight: 700;
    margin-bottom: 20px;
    line-height: 1.2;
  }
  .pijler-intro {
    color: var(--muted);
    line-height: 1.8; font-size: 15px;
  }

  /* Cases naast elkaar */
  .cases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .cases-grid.single {
    grid-template-columns: 1fr;
    max-width: 720px;
    margin: 0 auto;
  }
  .case-kaart {
    background: var(--white);
    border-radius: var(--radius);
    padding: 32px;
    display: flex; flex-direction: column;
  }
  .case-head {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
  }
  .case-head h3 {
    font-size: 22px; font-weight: 700;
    line-height: 1.2;
  }
  .case-logo {
    height: 36px; width: auto;
    max-width: 110px;
    object-fit: contain;
    flex-shrink: 0;
  }
  .case-kaart p {
    color: var(--muted);
    line-height: 1.8; font-size: 14px;
  }

  .dienst-cta {
    text-align: center;
    background: var(--navy);
    border-radius: var(--radius);
    padding: 64px;
    color: #fff;
  }
  .dienst-cta h2 { font-size: 32px; font-weight: 700; margin-bottom: 16px; }
  .dienst-cta p { opacity: .8; margin-bottom: 32px; font-size: 16px; }

  @media (max-width: 768px) {
    .dienst-page { padding: 32px 0 56px; }

    /* Header: foto eerst, dan tekst */
    .dienst-header {
      display: flex; flex-direction: column-reverse;
      gap: 28px;
      margin-bottom: 56px;
    }
    .dienst-header-tekst h1 {
      font-size: clamp(28px, 7vw, 36px);
      line-height: 1.15;
      margin-bottom: 16px;
    }
    .dienst-intro {
      font-size: 14px;
      line-height: 1.7;
      margin-bottom: 20px;
    }
    .dienst-header-img img {
      height: auto;
      aspect-ratio: 16 / 9;
      max-height: 240px;
    }

    /* Pijlers: foto eerst, dan tekst */
    .onderwijs-pijlers { margin-bottom: 56px; }
    .pijler-blok { margin-bottom: 56px; }
    .pijler-top {
      display: flex; flex-direction: column;
      gap: 20px;
      margin-bottom: 16px;
    }
    .pijler-top .pijler-img { order: -1; }
    .pijler-img {
      width: 100%;
    }
    .pijler-fader {
      aspect-ratio: 16 / 9;
      width: 100%;
    }
    .pijler-tekst h2 {
      font-size: clamp(22px, 5.5vw, 28px);
      margin-bottom: 12px;
    }
    .pijler-intro {
      font-size: 14px;
      line-height: 1.7;
    }
    .fader-dot { width: 10px; height: 10px; }

    /* Cases: 1 kolom, compacter */
    .cases-grid { grid-template-columns: 1fr; gap: 12px; }
    .cases-grid.single { max-width: none; }
    .case-kaart { padding: 20px; }
    .case-head {
      gap: 12px;
      margin-bottom: 12px;
    }
    .case-head h3 {
      font-size: 17px;
      line-height: 1.25;
    }
    .case-logo {
      height: 28px;
      max-width: 90px;
    }
    .case-kaart p {
      font-size: 13px;
      line-height: 1.7;
    }

    /* CTA compacter */
    .dienst-cta {
      padding: 36px 24px;
    }
    .dienst-cta h2 {
      font-size: 22px;
      line-height: 1.3;
      margin-bottom: 12px;
    }
    .dienst-cta p {
      font-size: 14px;
      margin-bottom: 24px;
    }
  }
</style>

<script>
  

  // Pijler faders
  document.querySelectorAll('[data-fader]').forEach(function(fader) {
    var faderSlides = fader.querySelectorAll('.fader-slide');
    var dots = fader.querySelectorAll('.fader-dot');
    if (faderSlides.length === 0) return;
    var idx = 0;

    function goTo(i) {
      faderSlides[idx].classList.remove('active');
      if (dots[idx]) dots[idx].classList.remove('active');
      idx = i;
      faderSlides[idx].classList.add('active');
      if (dots[idx]) dots[idx].classList.add('active');
    }

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        goTo(parseInt(dot.getAttribute('data-index')));
      });
    });

    if (faderSlides.length > 1) {
      setInterval(function() {
        goTo((idx + 1) % faderSlides.length);
      }, 4500);
    }
  });
</script>