---
import Layout from '../../layouts/Layout.astro';

const cases = [
  { slug: 'deelmobiliteit', tag: 'Natuurlijk!Deelmobiliteit', titel: 'Deelmobiliteit in Nederland versnellen', img: '/images/cases/deelmobiliteit.webp', diensten: ['Video', 'Webinar', 'Socials', 'Podcast'] },
  { slug: 'nsob', tag: 'Nederlandse School voor Openbaar Bestuur', titel: 'Hoogwaardig onderwijs en gefundeerd onderzoek over de publieke sector', img: '/images/cases/nsob.webp', diensten: ['Podcast', 'Video', 'Fotografie', 'Animaties'] },
  { slug: 'bob-kob', tag: 'BOB-KOB', titel: 'Praktijkgerichte opleider die vakmanschap in bouw en infra versterkt.', img: '/images/cases/bob-kob.webp', diensten: ['Video', 'Fotografie', 'Podcast'] },
  { slug: 'na-de-oorlog', tag: 'Stichting Na de Oorlog', titel: 'Verhalen uit de Tweede Wereldoorlog doorgeven aan nieuwe generaties.', img: '/images/cases/na-de-oorlog.webp', diensten: ['Video'] },
  { slug: 'rli', tag: 'Raad voor de leefomgeving en infrastructuur', titel: 'Adviesraad voor regering en parlement omtrent o.a. wonen, ruimtelijke ordening & milieu.', img: '/images/cases/rli.webp', diensten: ['Video', 'Webinars'] },
  { slug: 'vereniging-elektrische-rijders', tag: 'Vereniging Elektrische Rijders', titel: 'De stem van elektrisch rijden in Nederland.', img: '/images/cases/ver.webp', diensten: ['Video', 'Fotografie', 'Webinars'] },
];
---

<Layout title="Cases" description="Van deelmobiliteit en onderwijs tot overheid en infrastructuur, ontdek hoe Astrolads communicatie en media inzet voor blijvende maatschappelijke impact."> 
  <div class="cases-page">
    <div class="section-inner">
      <p class="section-label">Cases</p>
      <h1 class="section-title">Trots op alle gave projecten!</h1>

      <div class="cases-grid">
        {cases.map((c, i) => (
          <a href={'/cases/' + c.slug} class="case-card">
            <div class="case-img-wrap">
              <img
                src={c.img}
                alt={c.titel}
                width="600" height="380"
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : 'auto'}
                decoding={i === 0 ? 'sync' : 'async'}
              />
            </div>
            <div class="case-body">
              <p class="case-tag">{c.tag}</p>
              <h2>{c.titel}</h2>
              <div class="case-diensten">
                {c.diensten.map(d => <span class="pill">{d}</span>)}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>

<style>
  .cases-page { padding: 64px 0 96px; }
  .cases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .case-card {
    background: var(--white); border-radius: var(--radius);
    overflow: hidden; text-decoration: none; color: inherit;
    transition: transform .2s, box-shadow .2s;
  }
  .case-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(0,0,0,.1); }
  .case-img-wrap img { width: 100%; height: 240px; object-fit: cover; }
  .case-body { padding: 24px; }
  .case-tag { font-size: 11px; font-weight: 700; color: var(--orange-dark); text-transform: uppercase; letter-spacing: .07em; margin-bottom: 8px; }
  .case-body h2 { font-size: 20px; font-weight: 700; line-height: 1.3; margin-bottom: 16px; }
  .case-diensten { display: flex; flex-wrap: wrap; gap: 8px; }
  .pill {
    font-size: 12px; background: var(--bg);
    border-radius: 999px; padding: 4px 12px; color: var(--muted);
  }

  @media (max-width: 768px) {
    .cases-page { padding: 40px 0 56px; }
    .cases-grid { grid-template-columns: 1fr; gap: 16px; }
    .case-img-wrap img { height: 200px; }
    .case-body { padding: 20px; }
    .case-body h2 { font-size: 18px; }
    .pill { font-size: 11px; padding: 4px 10px; }
  }
</style>