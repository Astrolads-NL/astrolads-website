---
import LayoutNight from '../layouts/LayoutNight.astro';

// Slider 1: Hero/sfeer slider
const sfeerFotos = [
  '/images/community/sfeer-1.webp',
  '/images/community/sfeer-2.webp',
  '/images/community/sfeer-3.webp',
  '/images/community/sfeer-4.webp',
  '/images/community/sfeer-5.webp',
];

// Slider 2 — Events impressie
const eventFotos = [
  '/images/community/event-1.webp',
  '/images/community/event-2.webp',
  '/images/community/event-3.webp',
  '/images/community/event-4.webp',
];

// Slider 3 — Initiatieven impressie
const initiatiefFotos = [
  '/images/community/initiatief-1.webp',
  '/images/community/initiatief-2.webp',
  '/images/community/initiatief-3.webp',
];
---

<LayoutNight
  title="Community"
  description="Astrolads Community is de broedplaats voor creatief talent in Den Haag. Ontmoet gelijkgestemden tijdens events en kickstart waardevolle creatieve initiatieven."
>
  <div class="community-page">
    <div class="section-inner">

      <!-- Hero -->
      <section class="hero">
        <p class="eyebrow">Astrolads Community</p>
        <h1>De broedplaats voor creatief talent in Den Haag.</h1>
        <p class="hero-sub">
          Astrolads is de hotspot voor creatief talent in Den Haag. Om anderen te ontmoeten tijdens events én voor het kickstarten van waardevolle ideeën. Of je nu houdt van fotografie, kunst, muziek, games, design of juist nog helemaal aan het uitvogelen bent waar jouw talent ligt. Bij de Astrolads Community Hub vind je gelijkgestemden en kun je samen groeien!
        </p>
      </section>

      <!-- Sfeer slider -->
      <section class="slider-sectie">
        <div class="fader" data-fader>
          {sfeerFotos.map((f, i) => (
            <img src={f} alt={'Astrolads Community sfeer ' + (i + 1)} class:list={['fader-slide', { active: i === 0 }]} loading={i === 0 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : undefined} decoding={i === 0 ? 'sync' : 'async'} />
          ))}
          <div class="fader-dots">
            {sfeerFotos.map((_, i) => (
              <button class:list={['fader-dot', { active: i === 0 }]} data-index={i} aria-label={'Foto ' + (i + 1)}></button>
            ))}
          </div>
        </div>
      </section>

      <!-- Twee pijlers -->
      <section class="pijlers">
        <h2>Ontdek de community</h2>
        <p class="sectie-intro">De Astrolads Community bestaat met name uit twee grote pijlers:</p>
        <ol class="pijler-intro-lijst">
          <li><strong>Events</strong> — (terugkerende) events waar je nieuwe hobby's ontdekt, mensen leert kennen en gedeelde passies kan vieren.</li>
          <li><strong>Initiatieven</strong> — concepten en ideeën van externen die van Astrolads een zetje in de rug krijgen om van de grond te komen. Dit kan verschillen van financiële steun, materiële steun in de vorm van studio's en camera's, netwerk-mogelijkheden of ondernemersadvies.</li>
        </ol>

        <div class="pijler-grid">
          <a href="/community/events" class="pijler">
            <div class="pijler-fader" data-fader>
              {eventFotos.map((f, i) => (
                <img src={f} alt={'Event impressie ' + (i + 1)} class:list={['fader-slide', { active: i === 0 }]} loading="lazy" />
              ))}
              <div class="fader-dots">
                {eventFotos.map((_, i) => (
                  <button class:list={['fader-dot', { active: i === 0 }]} data-index={i} aria-label={'Foto ' + (i + 1)}></button>
                ))}
              </div>
            </div>
            <div class="pijler-body">
              <h3>Events</h3>
              <p>Laagdrempelige manier om met anderen in contact te komen en samen nieuwe vormen van creativiteit te ontdekken. Wees welkom!</p>
              <span class="btn-night-ghost">Naar de agenda →</span>
            </div>
          </a>

          <a href="/community/initiatieven" class="pijler">
            <div class="pijler-fader" data-fader>
              {initiatiefFotos.map((f, i) => (
                <img src={f} alt={'Initiatief impressie ' + (i + 1)} class:list={['fader-slide', { active: i === 0 }]} loading="lazy" />
              ))}
              <div class="fader-dots">
                {initiatiefFotos.map((_, i) => (
                  <button class:list={['fader-dot', { active: i === 0 }]} data-index={i} aria-label={'Foto ' + (i + 1)}></button>
                ))}
              </div>
            </div>
            <div class="pijler-body">
              <h3>Initiatieven</h3>
              <p>Astrolads ondersteunt waardevolle creatieve initiatieven die iets bijdragen aan de wereld, regio of simpelweg in het leven van creatives zelf. Wat is jouw idee?</p>
              <span class="btn-night-ghost">Bekijk initiatieven →</span>
            </div>
          </a>
        </div>
      </section>

      <!-- CTA pitch -->
      <section class="cta-sectie">
        <h2>Heb jij een idee?</h2>
        <p>Pitch je idee aan de co-founders van Astrolads en krijg een meeting waarin we samen kijken of we je verder kunnen helpen.</p>
        <a href="/community/initiatieven#pitch" class="btn-night-primary">Pitch je idee</a>
      </section>

    </div>
  </div>
</LayoutNight>

<style>
  .community-page { padding: 64px 0 96px; }

  .hero { text-align: center; margin-bottom: 80px; }
  .eyebrow {
    font-size: 13px; font-weight: 700;
    color: var(--orange);
    text-transform: uppercase; letter-spacing: .12em;
    margin-bottom: 16px;
  }
  .hero h1 {
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 24px;
    color: var(--night-text);
    max-width: 880px; margin-left: auto; margin-right: auto;
  }
  .hero-sub {
    color: var(--night-muted);
    font-size: 17px; line-height: 1.7;
    max-width: 720px; margin: 0 auto;
  }

  .btn-night-primary {
    background: var(--orange);
    color: #fff;
    padding: 12px 28px;
    border-radius: 999px;
    font-size: 14px; font-weight: 400;
    text-decoration: none;
    transition: opacity .2s, transform .15s;
    display: inline-block;
  }
  .btn-night-primary:hover { opacity: .88; transform: translateY(-1px); }

  .btn-night-ghost {
    background: transparent;
    border: 1px solid var(--night-border);
    color: var(--night-text);
    padding: 12px 28px;
    border-radius: 999px;
    font-size: 14px;
    text-decoration: none;
    transition: background .2s, border-color .2s;
    display: inline-block;
  }
  .btn-night-ghost:hover { background: var(--night-surface); border-color: var(--orange); }

  /* Sfeer slider */
  .slider-sectie { margin-bottom: 120px; }
  .fader {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 21/9;
    background: var(--night-surface);
    border: 1px solid var(--night-border);
  }
  .fader-slide {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; opacity: 0;
    transition: opacity .8s ease;
  }
  .fader-slide.active { opacity: 1; }
  .fader-dots {
    position: absolute; bottom: 16px; left: 50%;
    transform: translateX(-50%);
    display: flex; gap: 8px; z-index: 2;
  }
  .fader-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(255,255,255,.4);
    border: none; cursor: pointer; transition: background .2s; padding: 0;
  }
  .fader-dot.active { background: var(--orange); }

  /* Pijlers */
  .pijlers { margin-bottom: 120px; }
  .pijlers h2 {
    font-size: clamp(28px, 3vw, 36px);
    font-weight: 700;
    text-align: center;
    margin-bottom: 12px;
  }
  .sectie-intro {
    color: var(--night-muted);
    text-align: center;
    max-width: 640px; margin: 0 auto 20px;
  }
  .pijler-intro-lijst {
    color: var(--night-muted);
    max-width: 720px;
    margin: 0 auto 48px;
    padding-left: 24px;
    list-style: decimal;
    line-height: 1.7;
  }
  .pijler-intro-lijst li {
    margin-bottom: 12px;
    padding-left: 8px;
  }
  .pijler-intro-lijst li::marker {
    color: var(--orange);
    font-weight: 700;
  }
  .pijler-intro-lijst strong {
    color: var(--night-text);
    font-weight: 700;
  }
  .pijler-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .pijler {
    background: var(--night-surface);
    border: 1px solid var(--night-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color .2s;
    text-decoration: none;
    color: inherit;
  }
  .pijler:hover { border-color: var(--orange); }
  .pijler-fader {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }
  .pijler-fader .fader-slide {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; opacity: 0;
    transition: opacity .8s ease;
  }
  .pijler-fader .fader-slide.active { opacity: 1; }
  .pijler-fader .fader-dots {
    position: absolute; bottom: 12px; left: 50%;
    transform: translateX(-50%);
    display: flex; gap: 6px; z-index: 2;
  }
  .pijler-body { padding: 28px; }
  .pijler-body h3 {
    font-size: 22px; font-weight: 700;
    margin-bottom: 12px;
    color: var(--night-text);
  }
  .pijler-body p {
    color: var(--night-muted);
    font-size: 15px; line-height: 1.7;
    margin-bottom: 20px;
  }

  /* CTA pitch */
  .cta-sectie {
    text-align: center;
    padding: 64px 32px;
    background: var(--night-surface);
    border: 1px solid var(--night-border);
    border-radius: var(--radius);
  }
  .cta-sectie h2 {
    font-size: clamp(24px, 2.5vw, 32px);
    font-weight: 700;
    margin-bottom: 16px;
  }
  .cta-sectie p {
    color: var(--night-muted);
    max-width: 520px; margin: 0 auto 24px;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .community-page { padding: 32px 0 56px; }

    /* Hero compacter */
    .hero { margin-bottom: 40px; }
    .eyebrow { font-size: 12px; margin-bottom: 12px; }
    .hero h1 {
      font-size: clamp(26px, 7vw, 36px);
      line-height: 1.2;
      margin-bottom: 16px;
    }
    .hero-sub {
      font-size: 14px;
      line-height: 1.7;
    }

    /* Sfeer-fader: 16:9 ipv 21:9 */
    .slider-sectie { margin-bottom: 56px; }
    .fader { aspect-ratio: 16 / 9; }
    .fader-dot { width: 10px; height: 10px; }

    /* Pijlers: 1 kolom */
    .pijlers { margin-bottom: 56px; }
    .pijlers h2 {
      font-size: 24px;
      margin-bottom: 8px;
    }
    .sectie-intro {
      font-size: 14px;
      margin-bottom: 16px;
    }
    .pijler-intro-lijst {
      font-size: 14px;
      margin-bottom: 28px;
      padding-left: 20px;
    }
    .pijler-intro-lijst li {
      margin-bottom: 10px;
    }
    .pijler-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .pijler-fader { aspect-ratio: 16 / 9; }
    .pijler-fader .fader-dot { width: 10px; height: 10px; }
    .pijler-body { padding: 20px; }
    .pijler-body h3 { font-size: 18px; margin-bottom: 10px; }
    .pijler-body p {
      font-size: 14px;
      line-height: 1.7;
      margin-bottom: 16px;
    }

    /* CTA compacter */
    .cta-sectie {
      padding: 36px 24px;
    }
    .cta-sectie h2 {
      font-size: 22px;
      line-height: 1.3;
      margin-bottom: 12px;
    }
    .cta-sectie p {
      font-size: 14px;
      margin-bottom: 20px;
    }

    /* Knoppen compacter */
    .btn-night-primary,
    .btn-night-ghost {
      font-size: 13px;
      padding: 10px 22px;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-fader]').forEach(function(fader) {
    var slides = fader.querySelectorAll('.fader-slide');
    var dots = fader.querySelectorAll('.fader-dot');
    if (slides.length === 0) return;
    var current = 0;

    function goTo(index) {
      slides[current].classList.remove('active');
      if (dots[current]) dots[current].classList.remove('active');
      current = index;
      slides[current].classList.add('active');
      if (dots[current]) dots[current].classList.add('active');
    }

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        goTo(parseInt(dot.getAttribute('data-index')));
      });
    });

    if (slides.length > 1) {
      setInterval(function() {
        goTo((current + 1) % slides.length);
      }, 4500);
    }
  });
</script>