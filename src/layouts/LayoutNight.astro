---
import '../styles/global.css';
import NavNight from '../components/NavNight.astro';
import FooterNight from '../components/FooterNight.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'De Astrolads Community: een broedplaats voor creatief talent in Den Haag.',
  image = '/images/og-default.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Taalswitcher: bepaal het equivalent EN-pad
const path = Astro.url.pathname;
const nlToEn: Record<string, string> = {
  '/community': '/en/community',
  '/community/': '/en/community',
  '/community/events': '/en/community/events',
  '/community/initiatieven': '/en/community/initiatives',
};

const enPath = nlToEn[path] || '/en/community';
---

<!doctype html>
<html lang="nl" data-theme="night">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} | Astrolads Community</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Astrolads Community`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:site_name" content="Astrolads Community" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Astrolads Community`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Taal-alternatieven -->
    <link rel="alternate" hreflang="nl" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={new URL(enPath, Astro.site)} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <style>
      .taal-float {
        position: fixed;
        bottom: 28px; right: 28px;
        z-index: 200;
        display: flex; flex-direction: column; gap: 6px;
        background: var(--night-surface);
        border: 1px solid var(--night-border);
        border-radius: 999px;
        padding: 8px 10px;
        box-shadow: 0 4px 20px rgba(0,0,0,.4);
      }
      .taal-float-btn {
        font-size: 20px; line-height: 1;
        text-decoration: none;
        opacity: .35;
        transition: opacity .2s;
        display: block; text-align: center;
      }
      .taal-float-btn:hover { opacity: .8; }
      .taal-float-btn.active { opacity: 1; }
    </style>

    <!-- Google Analytics 4 (alleen na cookie consent) -->
    <script is:inline>
      if (localStorage.getItem('astrolads-cookie-consent') === 'accepted') {
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-BVMBH0N84J';
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag(){ window.dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', 'G-BVMBH0N84J', { anonymize_ip: true });
      }
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Naar hoofdcontent</a>
    <NavNight />
    <main id="main-content">
      <slot />
    </main>
    <FooterNight />
    <CookieBanner lang="nl" />
    <div class="taal-float" role="navigation" aria-label="Kies taal">
      <a href={path} class:list={['taal-float-btn', 'active']} title="Nederlands" aria-label="Nederlands (huidige taal)" aria-current="true">🇳🇱</a>
      <a href={enPath} class="taal-float-btn" title="English" aria-label="Schakel naar English">🇬🇧</a>
    </div>
  </body>
</html>